  "content": "<!-- wp:greenshift-blocks/element {\"id\":\"gsbp-c78252c\",\"type\":\"inner\",\"localId\":\"gsbp-c78252c\"} -->\n<div><!-- wp:greenshift-blocks/element {\"id\":\"gsbp-ebdcbd7\",\"tag\":\"section\",\"type\":\"inner\",\"localId\":\"gsbp-ebdcbd7\",\"align\":\"full\",\"dynamicAttributes\":[{\"name\":\"data-type\",\"value\":\"section-component\"}],\"styleAttributes\":{\"display\":[\"flex\"],\"justifyContent\":[\"center\"],\"flexDirection\":[\"column\"],\"alignItems\":[\"center\"],\"paddingRight\":[\"0\"],\"paddingLeft\":[\"0\"],\"paddingTop\":[\"0\"],\"paddingBottom\":[\"0\"],\"position\":[\"relative\"],\"paddingLink_Extra\":\"all\",\"backgroundImage\":[\"url(http://dasiy.com/wp-content/uploads/2026/05/a-spacex-satellite-hovering-over-earths-horizon-in-outer-space-showcasing-advanced-space-technology.-23779-1536x1022-2.jpg)\"],\"backgroundPosition\":[\"46% 49%\"],\"backgroundAttachment\":[\"fixed\"],\"backgroundSize\":[\"cover\"]},\"isVariation\":\"contentwrapper\"} -->\n<section class=\"gsbp-ebdcbd7 alignfull\" data-type=\"section-component\"><!-- wp:greenshift-blocks/element {\"id\":\"gsbp-b9bb0f0\",\"metadata\":{\"name\":\"Content Area\"},\"type\":\"inner\",\"localId\":\"gsbp-b9bb0f0\",\"dynamicAttributes\":[{\"name\":\"data-type\",\"value\":\"content-area-component\"}],\"styleAttributes\":{\"backgroundColor\":[\"#004182ad\"],\"width\":[\"100%\"],\"marginTop\":[\"\"],\"marginBottom\":[\"\"],\"paddingTop\":[\"48px\"],\"paddingLink_Extra\":\"tb\",\"paddingBottom\":[\"48px\"]},\"isVariation\":\"nocolumncontent\"} -->\n<div class=\"gsbp-b9bb0f0\" data-type=\"content-area-component\"><!-- wp:greenshift-blocks/element {\"id\":\"gsbp-bc14ad2\",\"tag\":\"section\",\"type\":\"inner\",\"localId\":\"gsbp-bc14ad2\",\"align\":\"full\",\"dynamicAttributes\":[{\"name\":\"data-type\",\"value\":\"section-component\"}],\"styleAttributes\":{\"display\":[\"flex\"],\"justifyContent\":[\"center\"],\"flexDirection\":[\"column\"],\"alignItems\":[\"center\"],\"paddingRight\":[\"var(\\u002d\\u002dwp\\u002d\\u002dcustom\\u002d\\u002dspacing\\u002d\\u002dside, min(3vw, 20px))\"],\"paddingLeft\":[\"var(\\u002d\\u002dwp\\u002d\\u002dcustom\\u002d\\u002dspacing\\u002d\\u002dside, min(3vw, 20px))\"],\"paddingTop\":[\"var(\\u002d\\u002dwp\\u002d\\u002dcustom\\u002d\\u002dspacing\\u002d\\u002dtop, 0px)\"],\"paddingBottom\":[\"var(\\u002d\\u002dwp\\u002d\\u002dcustom\\u002d\\u002dspacing\\u002d\\u002dbottom, 0px)\"],\"marginTop\":[\"0px\"],\"marginBottom\":[\"0px\"],\"paddingLink_Extra\":\"lr\",\"position\":[\"relative\"]},\"isVariation\":\"contentwrapper\"} -->\n<section class=\"gsbp-bc14ad2 alignfull\" data-type=\"section-component\"><!-- wp:greenshift-blocks/element {\"id\":\"gsbp-750cb75\",\"metadata\":{\"name\":\"Content Area\"},\"type\":\"inner\",\"localId\":\"gsbp-750cb75\",\"dynamicAttributes\":[{\"name\":\"data-type\",\"value\":\"content-area-component\"}],\"styleAttributes\":{\"maxWidth\":[\"100%\"],\"width\":[\"var(\\u002d\\u002dwp\\u002d\\u002dstyle\\u002d\\u002dglobal\\u002d\\u002dwide-size, 1200px)\"]},\"isVariation\":\"nocolumncontent\"} -->\n<div class=\"gsbp-750cb75\" data-type=\"content-area-component\"><!-- wp:greenshift-blocks/element {\"id\":\"gsbp-f55db6b\",\"type\":\"inner\",\"localId\":\"gsbp-f55db6b\",\"styleAttributes\":{\"marginLink_Extra\":\"all\",\"marginTop\":[\"0px\"],\"marginBottom\":[\"0px\"],\"marginLeft\":[\"0px\"],\"marginRight\":[\"0px\"],\"fontSize\":[\"17px\",null,\"16px\",\"16px\"]}} -->\n<div class=\"gsbp-f55db6b\"><!-- wp:greenshift-blocks/element {\"id\":\"gsbp-b9aac33\",\"textContent\":\"бһҖбҹ’бһҡбһҹбһҪбһ„бһ”бҹ’бһҡбҹғбһҹбһҺбһёбһҷбҹҚбһ“бһ·бһ„бһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚ бһҖбһ¶бһҡбһ”бһҫбһҖбһҖбһ¶бһҡбһ–бһ·бһӮбҹ’бһҡбҹ„бҹҮбһҷбҹ„бһ”бһӣбҹӢбһҮбһ¶бһ’бһ¶бһҡбһҺбҹҲбһӣбһҫбһҹбҹҒбһ…бһҖбҹ’бһҠбһёбһ–бҹ’бһҡбһ¶бһ„бһ”бҹ’бһҡбһҖбһ¶бһҹбһҹбҹ’бһҠбһёбһ–бһёбһ”бһ‘бһҠбҹ’бһӢбһ¶бһ“бһ”бһ…бҹ’бһ…бҹҒбһҖбһ‘бҹҒбһҹ бһ“бҹғбһӮбҹ’бһҡбһҝбһ„бһҹбһҳбҹ’бһ—бһ¶бһҡбҹҲбһ”бһҡбһ·бһҖбҹ’бһҒбһ¶бһҡбһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚ бһ“бһ·бһ„бһҹбҹҒбһ…бһҖбҹ’бһҠбһёбһ–бҹ’бһҡбһ¶бһ„бһ”бҹ’бһҡбһҖбһ¶бһҹбһҹбҹ’бһҠбһёбһ–бһёбһҖбһ¶бһҡбһ‘бһ‘бһҪбһӣбһҹбҹ’бһӮбһ¶бһӣбҹӢбһҷбһҗбһ¶бһ”бҹ’бһҡбһ—бҹҒбһ‘ бһ“бһ·бһ„бһҖбһ¶бһҡбһңбһ¶бһҷбһҸбһҳбҹ’бһӣбҹғбһўбһ“бһ»бһӣбҹ„бһҳбһ—бһ¶бһ–бһ“бҹғбһӮбҹ’бһҡбһҝбһ„бһҹбһҳбҹ’бһ—бһ¶бһҡбҹҲбһ”бһҡбһ·бһҖбҹ’бһҒбһ¶бһҡбһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚ\",\"tag\":\"h2\",\"localId\":\"gsbp-b9aac33\",\"styleAttributes\":{\"color\":[\"var(\\u002d\\u002dwp\\u002d\\u002dpreset\\u002d\\u002dcolor\\u002d\\u002dcontrastcolor, #fffffe)\"],\"lineHeight\":[\"1.5em\"],\"marginTop\":[\"0px\"],\"marginBottom\":[\"48px\"],\"marginLeft\":[\"0px\"],\"marginRight\":[\"0px\"]}} -->\n<h2 class=\"gsbp-b9aac33\">бһҖбҹ’бһҡбһҹбһҪбһ„бһ”бҹ’бһҡбҹғбһҹбһҺбһёбһҷбҹҚбһ“бһ·бһ„бһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚ бһҖбһ¶бһҡбһ”бһҫбһҖбһҖбһ¶бһҡбһ–бһ·бһӮбҹ’бһҡбҹ„бҹҮбһҷбҹ„бһ”бһӣбҹӢбһҮбһ¶бһ’бһ¶бһҡбһҺбҹҲбһӣбһҫбһҹбҹҒбһ…бһҖбҹ’бһҠбһёбһ–бҹ’бһҡбһ¶бһ„бһ”бҹ’бһҡбһҖбһ¶бһҹбһҹбҹ’бһҠбһёбһ–бһёбһ”бһ‘бһҠбҹ’бһӢбһ¶бһ“бһ”бһ…бҹ’бһ…бҹҒбһҖбһ‘бҹҒбһҹ бһ“бҹғбһӮбҹ’бһҡбһҝбһ„бһҹбһҳбҹ’бһ—бһ¶бһҡбҹҲбһ”бһҡбһ·бһҖбҹ’бһҒбһ¶бһҡбһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚ бһ“бһ·бһ„бһҹбҹҒбһ…бһҖбҹ’бһҠбһёбһ–бҹ’бһҡбһ¶бһ„бһ”бҹ’бһҡбһҖбһ¶бһҹбһҹбҹ’бһҠбһёбһ–бһёбһҖбһ¶бһҡбһ‘бһ‘бһҪбһӣбһҹбҹ’бһӮбһ¶бһӣбҹӢбһҷбһҗбһ¶бһ”бҹ’бһҡбһ—бҹҒбһ‘ бһ“бһ·бһ„бһҖбһ¶бһҡбһңбһ¶бһҷбһҸбһҳбҹ’бһӣбҹғбһўбһ“бһ»бһӣбҹ„бһҳбһ—бһ¶бһ–бһ“бҹғбһӮбҹ’бһҡбһҝбһ„бһҹбһҳбҹ’бһ—бһ¶бһҡбҹҲбһ”бһҡбһ·бһҖбҹ’бһҒбһ¶бһҡбһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚ</h2>\n<!-- /wp:greenshift-blocks/element -->\n\n<!-- wp:greenshift-blocks/element {\"id\":\"gsbp-45646a6\",\"textContent\":\"бһҖбҹ’бһҡбһҹбһҪбһ„бһ”бҹ’бһҡбҹғбһҹбһҺбһёбһҷбҹҚбһ“бһ·бһ„бһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚ (\\u003cstrong\\u003eбһҖ.бһ”.бһ‘.\\u003c/strong\\u003e) бһ“бһ·бһ„бһ“бһ·бһҷбҹҗбһҸбһҖбһҡбһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚбһҖбһҳбҹ’бһ–бһ»бһҮбһ¶ (\\u003cstrong\\u003eбһ“.бһ‘.бһҖ.\\u003c/strong\\u003e) бһҹбһјбһҳбһҮбһҳбҹ’бһҡбһ¶бһ”бһҮбһјбһ“бһ”бҹ’бһҡбһҸбһ·бһ”бһҸбҹ’бһҸбһ·бһҖбһҡ бһ—бһ¶бһӮбһёбһ–бһ¶бһҖбҹӢбһ–бҹҗбһ“бҹ’бһ’ бһ“бһ·бһ„бһҹбһ¶бһ’бһ¶бһҡбһҺбһҮбһ“бһҮбҹ’бһҡбһ¶бһ”бһҗбһ¶В \\u003cstrong\\u003eбһҖ.бһ”.бһ‘.\\u003c/strong\\u003eВ бһ“бһ·бһ„ \\u003cstrong\\u003eбһ“.бһ‘.бһҖ.\\u003c/strong\\u003eВ бһ”бһ¶бһ“бһҡбҹҖбһ”бһ…бҹҶбҹ–\",\"tag\":\"p\",\"localId\":\"gsbp-45646a6\",\"styleAttributes\":{\"marginTop\":[\"0px\"],\"marginBottom\":[\"24px\"],\"marginLeft\":[\"0px\"],\"marginRight\":[\"0px\"],\"color\":[\"var(\\u002d\\u002dwp\\u002d\\u002dpreset\\u002d\\u002dcolor\\u002d\\u002dcontrastcolor, #fffffe)\"]}} -->\n<p class=\"gsbp-45646a6\">бһҖбҹ’бһҡбһҹбһҪбһ„бһ”бҹ’бһҡбҹғбһҹбһҺбһёбһҷбҹҚбһ“бһ·бһ„бһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚ (<strong>бһҖ.бһ”.бһ‘.</strong>) бһ“бһ·бһ„бһ“бһ·бһҷбҹҗбһҸбһҖбһҡбһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚбһҖбһҳбҹ’бһ–бһ»бһҮбһ¶ (<strong>бһ“.бһ‘.бһҖ.</strong>) бһҹбһјбһҳбһҮбһҳбҹ’бһҡбһ¶бһ”бһҮбһјбһ“бһ”бҹ’бһҡбһҸбһ·бһ”бһҸбҹ’бһҸбһ·бһҖбһҡ бһ—бһ¶бһӮбһёбһ–бһ¶бһҖбҹӢбһ–бҹҗбһ“бҹ’бһ’ бһ“бһ·бһ„бһҹбһ¶бһ’бһ¶бһҡбһҺбһҮбһ“бһҮбҹ’бһҡбһ¶бһ”бһҗбһ¶В <strong>бһҖ.бһ”.бһ‘.</strong>В бһ“бһ·бһ„ <strong>бһ“.бһ‘.бһҖ.</strong>В бһ”бһ¶бһ“бһҡбҹҖбһ”бһ…бҹҶбҹ–</p>\n<!-- /wp:greenshift-blocks/element -->\n\n<!-- wp:greenshift-blocks/element {\"id\":\"gsbp-ebc3562\",\"textContent\":\"бҹЎ.бһҹбҹҒбһ…бһҖбҹ’бһҸбһёбһ–бҹ’бһҡбһ¶бһ„бһ”бҹ’бһҡбһҖбһ¶бһҹбһҹбҹ’бһҸбһёбһ–бһёбһ”бһ‘бһҠбҹ’бһӢбһ¶бһ“бһ”бһ…бҹ’бһ…бҹҒбһҖбһ‘бҹҒбһҹбһ“бҹғбһӮбҹ’бһҡбһҝбһ„бһҹбһҳбҹ’бһ—бһ¶бһҡбҹҲбһ”бһҡбһ·бһҖбҹ’бһҒбһ¶бһҡбһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚ\\u003cbr\\u003eбҹў.бһҹбҹҒбһ…бһҖбҹ’бһҸбһёбһ–бҹ’бһҡбһ¶бһ„бһ”бҹ’бһҡбһҖбһ¶бһҹбһҹбҹ’бһҸбһёбһ–бһёбһҖбһ¶бһҡбһ‘бһ‘бһҪбһӣбһҹбҹ’бһӮбһ¶бһӣбҹӢбһҷбһҗбһ¶бһ”бҹ’бһҡбһ—бҹҒбһ‘ бһ“бһ·бһ„бһҖбһ¶бһҡбһңбһ¶бһҷбһҸбһҳбҹ’бһӣбҹғбһўбһ“бһ»бһӣбҹ„бһҳбһ—бһ¶бһ–бһ“бҹғбһӮбҹ’бһҡбһҝбһ„бһҹбһҳбҹ’бһ—бһ¶бһҡбҹҲбһ”бһҡбһ·бһҖбҹ’бһҒбһ¶бһҡбһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚбҹ”\",\"tag\":\"p\",\"localId\":\"gsbp-ebc3562\",\"styleAttributes\":{\"marginTop\":[\"0px\"],\"marginBottom\":[\"24px\"],\"marginLeft\":[\"0px\"],\"marginRight\":[\"0px\"],\"color\":[\"var(\\u002d\\u002dwp\\u002d\\u002dpreset\\u002d\\u002dcolor\\u002d\\u002dcontrastcolor, #fffffe)\"],\"paddingRight\":[\"\"],\"paddingLeft\":[\"15px\"]}} -->\n<p class=\"gsbp-ebc3562\">бҹЎ.бһҹбҹҒбһ…бһҖбҹ’бһҸбһёбһ–бҹ’бһҡбһ¶бһ„бһ”бҹ’бһҡбһҖбһ¶бһҹбһҹбҹ’бһҸбһёбһ–бһёбһ”бһ‘бһҠбҹ’бһӢбһ¶бһ“бһ”бһ…бҹ’бһ…бҹҒбһҖбһ‘бҹҒбһҹбһ“бҹғбһӮбҹ’бһҡбһҝбһ„бһҹбһҳбҹ’бһ—бһ¶бһҡбҹҲбһ”бһҡбһ·бһҖбҹ’бһҒбһ¶бһҡбһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚ<br>бҹў.бһҹбҹҒбһ…бһҖбҹ’бһҸбһёбһ–бҹ’бһҡбһ¶бһ„бһ”бҹ’бһҡбһҖбһ¶бһҹбһҹбҹ’бһҸбһёбһ–бһёбһҖбһ¶бһҡбһ‘бһ‘бһҪбһӣбһҹбҹ’бһӮбһ¶бһӣбҹӢбһҷбһҗбһ¶бһ”бҹ’бһҡбһ—бҹҒбһ‘ бһ“бһ·бһ„бһҖбһ¶бһҡбһңбһ¶бһҷбһҸбһҳбҹ’бһӣбҹғбһўбһ“бһ»бһӣбҹ„бһҳбһ—бһ¶бһ–бһ“бҹғбһӮбҹ’бһҡбһҝбһ„бһҹбһҳбҹ’бһ—бһ¶бһҡбҹҲбһ”бһҡбһ·бһҖбҹ’бһҒбһ¶бһҡбһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚбҹ”</p>\n<!-- /wp:greenshift-blocks/element -->\n\n<!-- wp:greenshift-blocks/element {\"id\":\"gsbp-e01f2a7\",\"textContent\":\"бһҠбһҫбһҳбҹ’бһ”бһёбһұбҹ’бһҷбһҹбҹҒбһ…бһҖбҹ’бһҸбһёбһ–бҹ’бһҡбһ¶бһ„бһ”бҹ’бһҡбһҖбһ¶бһҹбһ‘бһ¶бҹҶбһ„бһ“бҹҒбҹҮбһҖбһ¶бһ“бҹӢбһҸбҹӮбһӮбҹ’бһҡбһ”бҹӢбһҮбҹ’бһҡбһ»бһ„бһҮбҹ’бһҡбҹ„бһҷВ \\u003cstrong\\u003eбһҖ.бһ”.бһ‘.\\u003c/strong\\u003eВ бһ“бһ·бһ„В \\u003cstrong\\u003eбһ“.бһ‘.бһҖ.\\u003c/strong\\u003eВ бһҹбһјбһҳбһўбһүбҹ’бһҮбһҫбһү бһ”бҹ’бһҡбһҸбһ·бһ”бһҸбҹ’бһҸбһ·бһҖбһҡ бһ—бһ¶бһӮбһёбһ–бһ¶бһҖбҹӢбһ–бҹҗбһ“бҹ’бһ’ бһ“бһ·бһ„бһҹбһ¶бһ’бһ¶бһҡбһҺбһҮбһ“бһ…бһјбһӣбһҡбһҪбһҳбһ•бҹ’бһҸбһӣбҹӢбһҳбһҸбһ·бһҷбҹ„бһ”бһӣбҹӢбһҠбһјбһ…бһҒбһ¶бһ„бһҖбҹ’бһҡбҹ„бһҳбҹ–\",\"tag\":\"p\",\"localId\":\"gsbp-e01f2a7\",\"styleAttributes\":{\"marginTop\":[\"0px\"],\"marginBottom\":[\"18px\"],\"marginLeft\":[\"0px\"],\"marginRight\":[\"0px\"],\"color\":[\"var(\\u002d\\u002dwp\\u002d\\u002dpreset\\u002d\\u002dcolor\\u002d\\u002dcontrastcolor, #fffffe)\"]}} -->\n<p class=\"gsbp-e01f2a7\">бһҠбһҫбһҳбҹ’бһ”бһёбһұбҹ’бһҷбһҹбҹҒбһ…бһҖбҹ’бһҸбһёбһ–бҹ’бһҡбһ¶бһ„бһ”бҹ’бһҡбһҖбһ¶бһҹбһ‘бһ¶бҹҶбһ„бһ“бҹҒбҹҮбһҖбһ¶бһ“бҹӢбһҸбҹӮбһӮбҹ’бһҡбһ”бҹӢбһҮбҹ’бһҡбһ»бһ„бһҮбҹ’бһҡбҹ„бһҷВ <strong>бһҖ.бһ”.бһ‘.</strong>В бһ“бһ·бһ„В <strong>бһ“.бһ‘.бһҖ.</strong>В бһҹбһјбһҳбһўбһүбҹ’бһҮбһҫбһү бһ”бҹ’бһҡбһҸбһ·бһ”бһҸбҹ’бһҸбһ·бһҖбһҡ бһ—бһ¶бһӮбһёбһ–бһ¶бһҖбҹӢбһ–бҹҗбһ“бҹ’бһ’ бһ“бһ·бһ„бһҹбһ¶бһ’бһ¶бһҡбһҺбһҮбһ“бһ…бһјбһӣбһҡбһҪбһҳбһ•бҹ’бһҸбһӣбҹӢбһҳбһҸбһ·бһҷбҹ„бһ”бһӣбҹӢбһҠбһјбһ…бһҒбһ¶бһ„бһҖбҹ’бһҡбҹ„бһҳбҹ–</p>\n<!-- /wp:greenshift-blocks/element --></div>\n<!-- /wp:greenshift-blocks/element --></div>\n<!-- /wp:greenshift-blocks/element --></section>\n<!-- /wp:greenshift-blocks/element --></div>\n<!-- /wp:greenshift-blocks/element --></section>\n<!-- /wp:greenshift-blocks/element -->\n\n<!-- wp:greenshift-blocks/element {\"id\":\"gsbp-d2eb43a\",\"tag\":\"section\",\"type\":\"inner\",\"localId\":\"gsbp-d2eb43a\",\"align\":\"full\",\"dynamicAttributes\":[{\"name\":\"data-type\",\"value\":\"section-component\"}],\"styleAttributes\":{\"display\":[\"flex\"],\"justifyContent\":[\"center\"],\"flexDirection\":[\"column\"],\"alignItems\":[\"center\"],\"paddingRight\":[\"var(\\u002d\\u002dwp\\u002d\\u002dcustom\\u002d\\u002dspacing\\u002d\\u002dside, min(3vw, 20px))\"],\"paddingLeft\":[\"var(\\u002d\\u002dwp\\u002d\\u002dcustom\\u002d\\u002dspacing\\u002d\\u002dside, min(3vw, 20px))\"],\"paddingTop\":[\"var(\\u002d\\u002dwp\\u002d\\u002dcustom\\u002d\\u002dspacing\\u002d\\u002dtop, 0px)\"],\"paddingBottom\":[\"var(\\u002d\\u002dwp\\u002d\\u002dcustom\\u002d\\u002dspacing\\u002d\\u002dbottom, 0px)\"],\"marginTop\":[\"0px\"],\"marginBottom\":[\"0px\"],\"paddingLink_Extra\":\"lr\",\"backgroundColor\":[\"var(\\u002d\\u002dwp\\u002d\\u002dpreset\\u002d\\u002dcolor\\u002d\\u002dcard-border, #f0f0f0)\"],\"backgroundPosition\":[\"50% 71%\"],\"backgroundSize\":[\"cover\"],\"position\":[\"relative\"]},\"isVariation\":\"contentwrapper\"} -->\n<section class=\"gsbp-d2eb43a alignfull\" data-type=\"section-component\"><!-- wp:greenshift-blocks/element {\"id\":\"gsbp-7023a58\",\"metadata\":{\"name\":\"Content Area\"},\"type\":\"inner\",\"localId\":\"gsbp-7023a58\",\"dynamicAttributes\":[{\"name\":\"data-type\",\"value\":\"content-area-component\"}],\"styleAttributes\":{\"maxWidth\":[\"100%\"],\"width\":[\"var(\\u002d\\u002dwp\\u002d\\u002dstyle\\u002d\\u002dglobal\\u002d\\u002dwide-size, 1200px)\"],\"marginLink_Extra\":\"tb\",\"marginTop\":[\"48px\"],\"marginBottom\":[\"48px\"]},\"isVariation\":\"nocolumncontent\"} -->\n<div class=\"gsbp-7023a58\" data-type=\"content-area-component\"><!-- wp:greenshift-blocks/element {\"id\":\"gsbp-953c7d5\",\"metadata\":{\"name\":\"div\"},\"type\":\"inner\",\"className\":\"gsbp-4f010c4\",\"localId\":\"gsbp-953c7d5\",\"styleAttributes\":{\"color\":[\"#3b3b3b\"],\"fontSize\":[\"17px\",null,\"16px\"]}} -->\n<div class=\"gsbp-4f010c4 gsbp-953c7d5\"><!-- wp:greenshift-blocks/element {\"id\":\"gsbp-af5f04b\",\"textContent\":\"\\u003cstrong\\u003eбһҖ. бһҹбҹҒбһ…бһҖбҹ’бһҸбһёбһ–бҹ’бһҡбһ¶бһ„бһ”бҹ’бһҡбһҖбһ¶бһҹбһҹбҹ’бһҸбһёбһ–бһёбһ”бһ‘бһҠбҹ’бһӢбһ¶бһ“бһ”бһ…бҹ’бһ…бҹҒбһҖбһ‘бҹҒбһҹбһ“бҹғбһӮбҹ’бһҡбһҝбһ„бһҹбһҳбҹ’бһ—бһ¶бһҡбҹҲбһ”бһҡбһ·бһҖбҹ’бһҒбһ¶бһҡбһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚ\\u003c/strong\\u003e\",\"tag\":\"h3\",\"localId\":\"gsbp-af5f04b\",\"styleAttributes\":{\"color\":[\"#004282\"],\"marginTop\":[\"0px\"],\"marginBottom\":[\"18px\"],\"marginLeft\":[\"0px\"],\"marginRight\":[\"0px\"]}} -->\n<h3 class=\"gsbp-af5f04b\"><strong>бһҖ. бһҹбҹҒбһ…бһҖбҹ’бһҸбһёбһ–бҹ’бһҡбһ¶бһ„бһ”бҹ’бһҡбһҖбһ¶бһҹбһҹбҹ’бһҸбһёбһ–бһёбһ”бһ‘бһҠбҹ’бһӢбһ¶бһ“бһ”бһ…бҹ’бһ…бҹҒбһҖбһ‘бҹҒбһҹбһ“бҹғбһӮбҹ’бһҡбһҝбһ„бһҹбһҳбҹ’бһ—бһ¶бһҡбҹҲбһ”бһҡбһ·бһҖбҹ’бһҒбһ¶бһҡбһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚ</strong></h3>\n<!-- /wp:greenshift-blocks/element -->\n\n<!-- wp:list {\"ordered\":true,\"className\":\"is-style-default\"} -->\n<ol class=\"wp-block-list is-style-default\"><!-- wp:list-item -->\n<li>бһ…бһјбһӣбһ‘бҹ…бһҖбһ¶бһ“бҹӢ&nbsp;<a href=\"https://go.gov.kh/mptc/pk-trc-ts-26\">https://go.gov.kh/mptc/pk-trc-ts-26</a>&nbsp;вҖӢбһ¬ бһҸбһ¶бһҳбһҡбһҷбҹҲ QR Code &nbsp;бһҮбһјбһ“бһ—бҹ’бһҮбһ¶бһ”бҹӢбһҳбһҖбһҮбһ¶бһҳбһҪбһҷ бһҠбһҫбһҳбҹ’бһ”бһёбһ‘бһ¶бһүбһҷбһҖбһҹбҹҒбһ…бһҖбҹ’бһҸбһёбһ–бҹ’бһҡбһ¶бһ„бһ”бҹ’бһҡбһҖбһ¶бһҹбһҹбҹ’бһҸбһёбһ–бһёбһ”бһ‘бһҠбҹ’бһӢбһ¶бһ“бһ”бһ…бҹ’бһ…бҹҒбһҖбһ‘бҹҒбһҹбһ“бҹғбһӮбҹ’бһҡбһҝбһ„бһҹбһҳбҹ’бһ—бһ¶бһҡбҹҲбһ”бһҡбһ·бһҖбҹ’бһҒбһ¶бһҡбһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚбҹ”</li>\n<!-- /wp:list-item -->\n\n<!-- wp:list-item -->\n<li>бһ…бһјбһӣбһ‘бҹ…бһҖбһ¶бһ“бҹӢ вҖӢ<a href=\"https://go.gov.kh/mptc/cm-ts-26\">https://go.gov.kh/mptc/cm-ts-26</a>&nbsp;бһ¬ бһҸбһ¶бһҳбһҡбһҷбҹҲ QR Code &nbsp;бһҮбһјбһ“бһ—бҹ’бһҮбһ¶бһ”бҹӢбһҳбһҖбһҮбһ¶бһҳбһҪбһҷ бһҠбһҫбһҳбҹ’бһ”бһёбһ‘бһ¶бһүбһҷбһҖбһ‘бһҳбҹ’бһҡбһ„бҹӢбһӮбҹҶбһҡбһјвҖӢбһ•бҹ’бһҸбһӣбҹӢвҖӢбһҳбһҸбһ·бһҷбҹ„бһ”бһӣбҹӢбһӣбһҫбһҹбҹҒбһ…бһҖбҹ’бһҸбһёбһ–бҹ’бһҡбһ¶бһ„бһ”бҹ’бһҡбһҖбһ¶бһҹбһ“бҹҒбҹҮбҹ”</li>\n<!-- /wp:list-item -->\n\n<!-- wp:list-item -->\n<li>бһ”бһүбҹ’бһҮбһјбһ“бһҳбһҸбһ·бһҷбҹ„бһ”бһӣбҹӢбһҳбһҖбһңбһ·бһүбһҸбһ¶бһҳбһҡбһҷбҹҲ&nbsp;<a href=\"https://go.gov.kh/mptc/trc-ts-26-form\">https://go.gov.kh/mptc/trc-ts-26-form</a>&nbsp;бһ¬бһҸбһ¶бһҳбһҡбһҷбҹҲ QR Code &nbsp;бһҮбһјбһ“бһ—бҹ’бһҮбһ¶бһ”бҹӢбһҳбһҖбһҮбһ¶бһҳбһҪбһҷ&nbsp;<strong>бһұбҹ’бһҷбһ”бһ¶бһ“вҖӢбһҸбҹ’бһҡбһ№бһҳбһҠбҹҶбһҺбһ¶бһ…бҹӢбһҗбҹ’бһ„бҹғбһ‘бһёбҹўбҹҘ бһҒбҹӮбһ§бһҹбһ—бһ¶ бһҶбҹ’бһ“бһ¶бҹҶбҹўбҹ бҹўбҹҰ</strong>бҹ”</li>\n<!-- /wp:list-item --></ol>\n<!-- /wp:list --></div>\n<!-- /wp:greenshift-blocks/element -->\n\n<!-- wp:greenshift-blocks/element {\"id\":\"gsbp-d7bb46f\",\"metadata\":{\"name\":\"div\"},\"type\":\"inner\",\"className\":\"gsbp-4f010c4\",\"localId\":\"gsbp-d7bb46f\",\"styleAttributes\":{\"color\":[\"#3b3b3b\"],\"marginTop\":[\"48px\"],\"marginBottom\":[\"\"],\"fontSize\":[\"17px\",null,\"16px\"]}} -->\n<div class=\"gsbp-4f010c4 gsbp-d7bb46f\"><!-- wp:greenshift-blocks/element {\"id\":\"gsbp-9643342\",\"textContent\":\"бһҒ. бһҹбҹҒбһ…бһҖбҹ’бһҸбһёбһ–бҹ’бһҡбһ¶бһ„бһ”бҹ’бһҡбһҖбһ¶бһҹбһҹбҹ’бһҸбһёбһ–бһёбһҖбһ¶бһҡбһ‘бһ‘бһҪбһӣбһҹбҹ’бһӮбһ¶бһӣбҹӢбһҷбһҗбһ¶бһ”бҹ’бһҡбһ—бҹҒбһ‘ бһ“бһ·бһ„бһҖбһ¶бһҡбһңбһ¶бһҷбһҸбһҳбҹ’бһӣбҹғбһўбһ“бһ»бһӣбҹ„бһҳбһ—бһ¶бһ–бһ“бҹғбһӮбҹ’бһҡбһҝбһ„бһҹбһҳбҹ’бһ—бһ¶бһҡбҹҲбһ”бһҡбһ·бһҖбҹ’бһҒбһ¶бһҡбһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚ\",\"tag\":\"h3\",\"localId\":\"gsbp-9643342\",\"styleAttributes\":{\"color\":[\"#004282\"],\"marginTop\":[\"0px\"],\"marginBottom\":[\"18px\"],\"marginLeft\":[\"0px\"],\"marginRight\":[\"0px\"],\"textDecoration\":[\"none\"]}} -->\n<h3 class=\"gsbp-9643342\">бһҒ. бһҹбҹҒбһ…бһҖбҹ’бһҸбһёбһ–бҹ’бһҡбһ¶бһ„бһ”бҹ’бһҡбһҖбһ¶бһҹбһҹбҹ’бһҸбһёбһ–бһёбһҖбһ¶бһҡбһ‘бһ‘бһҪбһӣбһҹбҹ’бһӮбһ¶бһӣбҹӢбһҷбһҗбһ¶бһ”бҹ’бһҡбһ—бҹҒбһ‘ бһ“бһ·бһ„бһҖбһ¶бһҡбһңбһ¶бһҷбһҸбһҳбҹ’бһӣбҹғбһўбһ“бһ»бһӣбҹ„бһҳбһ—бһ¶бһ–бһ“бҹғбһӮбҹ’бһҡбһҝбһ„бһҹбһҳбҹ’бһ—бһ¶бһҡбҹҲбһ”бһҡбһ·бһҖбҹ’бһҒбһ¶бһҡбһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚ</h3>\n<!-- /wp:greenshift-blocks/element -->\n\n<!-- wp:list {\"ordered\":true,\"className\":\"is-style-default\"} -->\n<ol class=\"wp-block-list is-style-default\"><!-- wp:list-item -->\n<li>бһ…бһјбһӣбһ‘бҹ…бһҖбһ¶бһ“бҹӢ&nbsp;<a href=\"https://go.gov.kh/mptc/pk-trc-ta-26\">https://go.gov.kh/mptc/pk-trc-ta-26</a>&nbsp;вҖӢбһ¬ бһҸбһ¶бһҳбһҡбһҷбҹҲ QR Code &nbsp;бһҮбһјбһ“бһ—бҹ’бһҮбһ¶бһ”бҹӢбһҳбһҖбһҮбһ¶бһҳбһҪбһҷ бһҠбһҫбһҳбҹ’бһ”бһёбһ‘бһ¶бһүбһҷбһҖбһҹбҹҒбһ…бһҖбҹ’бһҸбһёбһ–бҹ’бһҡбһ¶бһ„бһ”бҹ’бһҡбһҖбһ¶бһҹбһҹбҹ’бһҸбһёбһ–бһёбһҖбһ¶бһҡбһ‘бһ‘бһҪбһӣбһҹбҹ’бһӮбһ¶бһӣбҹӢбһҷбһҗбһ¶бһ”бҹ’бһҡбһ—бҹҒбһ‘ бһ“бһ·бһ„бһҖбһ¶бһҡбһңбһ¶бһҷбһҸбһҳбҹ’бһӣбҹғбһўбһ“бһ»бһӣбҹ„бһҳбһ—бһ¶бһ–бһ“бҹғбһӮбҹ’бһҡбһҝбһ„бһҹбһҳбҹ’бһ—бһ¶бһҡбҹҲбһ”бһҡбһ·бһҖбҹ’бһҒбһ¶бһҡбһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚбҹ”</li>\n<!-- /wp:list-item -->\n\n<!-- wp:list-item -->\n<li>бһ…бһјбһӣбһ‘бҹ…бһҖбһ¶бһ“бҹӢ&nbsp;<a href=\"https://go.gov.kh/mptc/cm-ta-26\">https://go.gov.kh/mptc/cm-ta-26</a>&nbsp;вҖӢбһ¬ бһҸбһ¶бһҳбһҡбһҷбҹҲ QR Code &nbsp;бһҮбһјбһ“бһ—бҹ’бһҮбһ¶бһ”бҹӢбһҳбһҖбһҮбһ¶бһҳбһҪбһҷ бһҠбһҫбһҳбҹ’бһ”бһёбһ‘бһ¶бһүбһҷбһҖбһ‘бһҳбҹ’бһҡбһ„бҹӢбһӮбҹҶбһҡбһјвҖӢбһ•бҹ’бһҸбһӣбҹӢвҖӢбһҳбһҸбһ·бһҷбҹ„бһ”бһӣбҹӢбһӣбһҫбһҹбҹҒбһ…бһҖбҹ’бһҸбһёбһ–бҹ’бһҡбһ¶бһ„бһ”бҹ’бһҡбһҖбһ¶бһҹбһ“бҹҒбҹҮбҹ”</li>\n<!-- /wp:list-item -->\n\n<!-- wp:list-item -->\n<li>бһ”бһүбҹ’бһҮбһјбһ“бһҳбһҸбһ·бһҷбҹ„бһ”бһӣбҹӢбһҳбһҖбһңбһ·бһүбһҸбһ¶бһҳбһҡбһҷбҹҲ&nbsp;<a href=\"https://go.gov.kh/mptc/trc-ta-26-form\">https://go.gov.kh/mptc/trc-ta-26-form</a>&nbsp;бһ¬ бһҸбһ¶бһҳбһҡбһҷбҹҲ QR Code &nbsp;бһҮбһјбһ“бһ—бҹ’бһҮбһ¶бһ”бҹӢбһҳбһҖбһҮбһ¶бһҳбһҪбһҷ&nbsp;<strong>бһұбҹ’бһҷбһ”бһ¶бһ“вҖӢбһҸбҹ’бһҡбһ№бһҳбһҠбҹҶбһҺбһ¶бһ…бҹӢбһҗбҹ’бһ„бҹғбһ‘бһёбҹўбҹҘ бһҒбҹӮбһ§бһҹбһ—бһ¶ бһҶбҹ’бһ“бһ¶бҹҶбҹўбҹ бҹўбҹҰ</strong>бҹ”</li>\n<!-- /wp:list-item --></ol>\n<!-- /wp:list --></div>\n<!-- /wp:greenshift-blocks/element --></div>\n<!-- /wp:greenshift-blocks/element --></section>\n<!-- /wp:greenshift-blocks/element -->\n\n<!-- wp:greenshift-blocks/element {\"id\":\"gsbp-ad20a1b\",\"tag\":\"section\",\"type\":\"inner\",\"localId\":\"gsbp-ad20a1b\",\"align\":\"full\",\"dynamicAttributes\":[{\"name\":\"data-type\",\"value\":\"section-component\"}],\"styleAttributes\":{\"display\":[\"flex\"],\"justifyContent\":[\"center\"],\"flexDirection\":[\"column\"],\"alignItems\":[\"center\"],\"paddingRight\":[\"var(\\u002d\\u002dwp\\u002d\\u002dcustom\\u002d\\u002dspacing\\u002d\\u002dside, min(3vw, 20px))\"],\"paddingLeft\":[\"var(\\u002d\\u002dwp\\u002d\\u002dcustom\\u002d\\u002dspacing\\u002d\\u002dside, min(3vw, 20px))\"],\"paddingTop\":[\"var(\\u002d\\u002dwp\\u002d\\u002dcustom\\u002d\\u002dspacing\\u002d\\u002dtop, 0px)\"],\"paddingBottom\":[\"var(\\u002d\\u002dwp\\u002d\\u002dcustom\\u002d\\u002dspacing\\u002d\\u002dbottom, 0px)\"],\"marginTop\":[\"0px\"],\"marginBottom\":[\"0px\"],\"paddingLink_Extra\":\"lr\",\"backgroundColor\":[\"#adadad\"],\"backgroundImage\":[\"url(http://dasiy.com/wp-content/uploads/2026/05/Untitled-1-300x214-1.jpg)\"],\"backgroundPosition\":[\"50% 71%\"],\"backgroundSize\":[\"cover\"],\"position\":[\"relative\"]},\"isVariation\":\"contentwrapper\"} -->\n<section class=\"gsbp-ad20a1b alignfull\" data-type=\"section-component\"><!-- wp:greenshift-blocks/element {\"id\":\"gsbp-ae1ef7b\",\"metadata\":{\"name\":\"Content Area\"},\"type\":\"inner\",\"localId\":\"gsbp-ae1ef7b\",\"dynamicAttributes\":[{\"name\":\"data-type\",\"value\":\"content-area-component\"}],\"styleAttributes\":{\"maxWidth\":[\"100%\"],\"width\":[\"var(\\u002d\\u002dwp\\u002d\\u002dstyle\\u002d\\u002dglobal\\u002d\\u002dwide-size, 1200px)\"],\"marginLink_Extra\":\"tb\",\"marginTop\":[\"48px\"],\"marginBottom\":[\"48px\"]},\"isVariation\":\"nocolumncontent\"} -->\n<div class=\"gsbp-ae1ef7b\" data-type=\"content-area-component\"><!-- wp:greenshift-blocks/element {\"id\":\"gsbp-ae15c2d\",\"type\":\"inner\",\"className\":\"gsbp-4f010c4\",\"localId\":\"gsbp-ae15c2d\",\"styleAttributes\":{\"color\":[\"var(\\u002d\\u002dwp\\u002d\\u002dpreset\\u002d\\u002dcolor\\u002d\\u002dcontrastcolor, #fffffe)\"],\"fontSize\":[null,null,\"16px\"]}} -->\n<div class=\"gsbp-4f010c4 gsbp-ae15c2d\"><!-- wp:greenshift-blocks/element {\"id\":\"gsbp-c6a23e3\",\"textContent\":\"бһўбһ¶бһҹбҹ’бһҡбҹҗбһҷбһ бҹҒбһҸбһ»бһ“бҹҒбҹҮвҖӢ бһҹбһјбһҳбһ”бһ»бһӮбҹ’бһӮбһӣбһ–бһ¶бһҖбҹӢбһ–бҹҗбһ“бҹ’бһ’вҖӢбһ“бһ·бһ„вҖӢбһҹбһ¶бһ’бһ¶бһҡбһҺбһҮбһ“бһ‘бһ¶бҹҶбһ„бһўбһҹбҹӢ бһҳбҹҒбһҸбҹ’бһҸбһ¶бһҮбҹ’бһҡбһ¶бһ”бһҮбһ¶бһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“ бһ“бһ·бһ„вҖӢбһ…бһјбһӣбһҡбһҪбһҳвҖӢбһ…бһ»бҹҮбһҲбҹ’бһҳбҹ„бҹҮбһ–бһ·бһӮбҹ’бһҡбҹ„бҹҮбһҷбҹ„бһ”бһӣбҹӢвҖӢбһҸбһ¶бһҳвҖӢбһҖбһ¶бһҡбһӮбһҪбһҡбҹ”\",\"tag\":\"p\",\"localId\":\"gsbp-c6a23e3\",\"styleAttributes\":{\"marginLink_Extra\":\"all\",\"marginTop\":[\"0px\"],\"marginBottom\":[\"0px\"],\"marginLeft\":[\"0px\"],\"marginRight\":[\"0px\"]}} -->\n<p class=\"gsbp-c6a23e3\">бһўбһ¶бһҹбҹ’бһҡбҹҗбһҷбһ бҹҒбһҸбһ»бһ“бҹҒбҹҮвҖӢ бһҹбһјбһҳбһ”бһ»бһӮбҹ’бһӮбһӣбһ–бһ¶бһҖбҹӢбһ–бҹҗбһ“бҹ’бһ’вҖӢбһ“бһ·бһ„вҖӢбһҹбһ¶бһ’бһ¶бһҡбһҺбһҮбһ“бһ‘бһ¶бҹҶбһ„бһўбһҹбҹӢ бһҳбҹҒбһҸбҹ’бһҸбһ¶бһҮбҹ’бһҡбһ¶бһ”бһҮбһ¶бһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“ бһ“бһ·бһ„вҖӢбһ…бһјбһӣбһҡбһҪбһҳвҖӢбһ…бһ»бҹҮбһҲбҹ’бһҳбҹ„бҹҮбһ–бһ·бһӮбҹ’бһҡбҹ„бҹҮбһҷбҹ„бһ”бһӣбҹӢвҖӢбһҸбһ¶бһҳвҖӢбһҖбһ¶бһҡбһӮбһҪбһҡбҹ”</p>\n<!-- /wp:greenshift-blocks/element -->\n\n<!-- wp:greenshift-blocks/element {\"id\":\"gsbp-dd73dc9\",\"textContent\":\"бһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢвҖӢбһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“вҖӢбһ”бһ“бҹ’бһҗбҹӮбһҳвҖӢбҹ–\",\"tag\":\"h4\",\"localId\":\"gsbp-dd73dc9\",\"styleAttributes\":{\"color\":[\"var(\\u002d\\u002dwp\\u002d\\u002dpreset\\u002d\\u002dcolor\\u002d\\u002dcontrastcolor, #fffffe)\"],\"marginTop\":[\"24px\",null,null],\"marginBottom\":[\"12px\",null,null],\"marginLeft\":[\"0px\"],\"marginRight\":[\"0px\"]}} -->\n<h4 class=\"gsbp-dd73dc9\">бһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢвҖӢбһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“вҖӢбһ”бһ“бҹ’бһҗбҹӮбһҳвҖӢбҹ–</h4>\n<!-- /wp:greenshift-blocks/element -->\n\n<!-- wp:greenshift-blocks/element {\"id\":\"gsbp-a9fa734\",\"type\":\"inner\",\"localId\":\"gsbp-a9fa734\",\"styleAttributes\":{\"fontSize\":[null,null,\"16px\"]}} -->\n<div c