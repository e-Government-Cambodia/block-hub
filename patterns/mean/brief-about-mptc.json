  "title": "Brief About MPTC",
  "content": "<!-- wp:greenshift-blocks/element {\"id\":\"gsbp-0001449\",\"tag\":\"section\",\"type\":\"inner\",\"localId\":\"gsbp-0001449\",\"align\":\"full\",\"dynamicAttributes\":[{\"name\":\"data-type\",\"value\":\"section-component\"}],\"styleAttributes\":{\"display\":[\"flex\"],\"justifyContent\":[\"center\"],\"flexDirection\":[\"column\"],\"alignItems\":[\"center\"],\"paddingRight\":[\"var(\\u002d\\u002dwp\\u002d\\u002dcustom\\u002d\\u002dspacing\\u002d\\u002dside, min(3vw, 20px))\"],\"paddingLeft\":[\"var(\\u002d\\u002dwp\\u002d\\u002dcustom\\u002d\\u002dspacing\\u002d\\u002dside, min(3vw, 20px))\"],\"paddingTop\":[\"var(\\u002d\\u002dwp\\u002d\\u002dcustom\\u002d\\u002dspacing\\u002d\\u002dtop, 0px)\"],\"paddingBottom\":[\"var(\\u002d\\u002dwp\\u002d\\u002dcustom\\u002d\\u002dspacing\\u002d\\u002dbottom, 0px)\"],\"marginTop\":[\"0px\"],\"marginBottom\":[\"0px\"],\"paddingLink_Extra\":\"lr\",\"position\":[\"relative\"],\"backgroundColor\":[\"var(\\u002d\\u002dwp\\u002d\\u002dpreset\\u002d\\u002dcolor\\u002d\\u002dcard-border, #f0f0f0)\"]},\"isVariation\":\"contentwrapper\"} -->\n<section class=\"gsbp-0001449 alignfull\" data-type=\"section-component\"><!-- wp:greenshift-blocks/element {\"id\":\"gsbp-edbf021\",\"type\":\"inner\",\"localId\":\"gsbp-edbf021\",\"styleAttributes\":{\"marginTop\":[\"48px\"],\"marginBottom\":[\"48px\"],\"marginLeft\":[\"0px\"],\"marginRight\":[\"0px\"],\"paddingLink_Extra\":\"all\",\"paddingTop\":[\"0px\"],\"paddingBottom\":[\"0px\"],\"paddingLeft\":[\"0px\"],\"paddingRight\":[\"0px\"],\"marginLink_Extra\":\"tb\"}} -->\n<div class=\"gsbp-edbf021\"><!-- wp:greenshift-blocks/element {\"id\":\"gsbp-7555071\",\"textContent\":\"бһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“бһҹбһ„бҹ’бһҒбҹҒбһ”бһҹбҹ’бһҸбһёбһ–бһёбһҖбҹ’бһҡбһҹбһҪбһ„вҖӢ\",\"tag\":\"h2\",\"localId\":\"gsbp-7555071\",\"styleAttributes\":{\"marginLink_Extra\":\"all\",\"marginTop\":[\"0\"],\"marginBottom\":[\"0\"],\"marginLeft\":[\"0\"],\"marginRight\":[\"0\"]}} -->\n<h2 class=\"gsbp-7555071\">бһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“бһҹбһ„бҹ’бһҒбҹҒбһ”бһҹбҹ’бһҸбһёбһ–бһёбһҖбҹ’бһҡбһҹбһҪбһ„вҖӢ</h2>\n<!-- /wp:greenshift-blocks/element --></div>\n<!-- /wp:greenshift-blocks/element -->\n\n<!-- wp:greenshift-blocks/element {\"id\":\"gsbp-e08ed10\",\"metadata\":{\"name\":\"Content Area\"},\"type\":\"inner\",\"localId\":\"gsbp-e08ed10\",\"dynamicAttributes\":[{\"name\":\"data-type\",\"value\":\"content-area-component\"}],\"styleAttributes\":{\"maxWidth\":[\"100%\"],\"width\":[\"var(\\u002d\\u002dwp\\u002d\\u002dstyle\\u002d\\u002dglobal\\u002d\\u002dwide-size, 1200px)\"],\"backgroundColor\":[\"var(\\u002d\\u002dwp\\u002d\\u002dpreset\\u002d\\u002dcolor\\u002d\\u002dcontrastcolor, #fffffe)\"],\"marginTop\":[\"\"],\"marginBottom\":[\"48px\"],\"borderRadiusLink_Extra\":true,\"borderTopLeftRadius\":[\"7px\"],\"borderBottomLeftRadius\":[\"7px\"],\"borderTopRightRadius\":[\"7px\"],\"borderBottomRightRadius\":[\"7px\"],\"paddingTop\":[\"24px\"],\"paddingBottom\":[\"4em\"],\"paddingLeft\":[\"24px\"],\"paddingRight\":[\"24px\"],\"boxShadow\":[\"var(\\u002d\\u002dwp\\u002d\\u002dpreset\\u002d\\u002dshadow\\u002d\\u002dsoft, 0px 15px 30px 0px rgba(119, 123, 146, 0.1))\"]},\"isVariation\":\"nocolumncontent\"} -->\n<div class=\"gsbp-e08ed10\" data-type=\"content-area-component\"><!-- wp:greenshift-blocks/element {\"id\":\"gsbp-e1eda41\",\"type\":\"inner\",\"localId\":\"gsbp-e1eda41\",\"styleAttributes\":{\"marginLink_Extra\":\"all\",\"marginTop\":[\"0px\"],\"marginBottom\":[\"0px\"],\"marginLeft\":[\"0px\"],\"marginRight\":[\"0px\"],\"paddingLink_Extra\":\"all\",\"paddingTop\":[\"0px\"],\"paddingBottom\":[\"0px\"],\"paddingLeft\":[\"0px\"],\"paddingRight\":[\"0px\"],\"alignSelf\":[\"start\"],\"justifySelf\":[\"start\"]}} -->\n<div class=\"gsbp-e1eda41\"><!-- wp:greenshift-blocks/element {\"id\":\"gsbp-b3929e6\",\"textContent\":\"бһ…бһҖбҹ’бһҒбһ»бһңбһ·бһҹбҹҗбһҷ\",\"tag\":\"h3\",\"localId\":\"gsbp-b3929e6\",\"styleAttributes\":{\"color\":[\"#004282\"],\"marginTop\":[\"15px\"],\"marginBottom\":[\"0px\"],\"marginLeft\":[\"0px\"],\"marginRight\":[\"0px\"],\"fontSize\":[\"22px\"]}} -->\n<h3 class=\"gsbp-b3929e6\">бһ…бһҖбҹ’бһҒбһ»бһңбһ·бһҹбҹҗбһҷ</h3>\n<!-- /wp:greenshift-blocks/element -->\n\n<!-- wp:greenshift-blocks/element {\"id\":\"gsbp-5fa756b\",\"textContent\":\"бһҮбҹҶбһҡбһ»бһүбһҖбһ¶бһҡбһ—бҹ’бһҮбһ¶бһ”бҹӢбһ бҹҒбһҠбҹ’бһӢбһ¶бһҡбһ…бһ“бһ¶бһҹбһҳбҹ’бһ–бҹҗбһ“бҹ’бһ’ бһ“бһ·бһ„бһҖбһ¶бһҡбһ•бҹ’бһҸбһӣбҹӢбһҹбҹҒбһңбһ¶ бһӣбһҫбһңбһ·бһҹбҹҗбһҷбһ”бҹ’бһҡбҹғбһҹбһҺбһёбһҷбҹҚ бһ“бһ·бһ„бһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚ бһ–бҹ’бһҡбһҳбһ‘бһ¶бҹҶбһ„бһ”бһ…бҹ’бһ…бҹҒбһҖбһңбһ·бһ‘бҹ’бһҷбһ¶бһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚбһ“бһ·бһ„бһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“ бһ“бҹ…бһӮбҹ’бһҡбһ”бҹӢбһ‘бһёбһҖбһ“бҹ’бһӣбҹӮбһ„бһ‘бһ¶бҹҶбһ„бһўбһҹбҹӢбһҖбҹ’бһ“бһ»бһ„бһ”бҹ’бһҡбһ‘бҹҒбһҹбһҖбһҳбҹ’бһ–бһ»бһҮбһ¶ бһ“бҹ…бһҖбҹ’бһ“бһ»бһ„бһҸбҹҶбһ”бһ“бҹӢ бһ“бһ·бһ„бһ–бһ·бһ—бһ–бһӣбҹ„бһҖ бһ”бҹ’бһҡбһҖбһ”бһҠбҹ„бһҷбһӮбһ»бһҺбһ—бһ¶бһ– бһ”бҹ’бһҡбһҹбһ·бһ‘бҹ’бһ’бһ—бһ¶бһ– бһ“бһ·бһ„бһҹбҹҗбһҖбҹ’бһҸбһ·бһҹбһ·бһ‘бҹ’бһ’бһ·бһ—бһ¶бһ–бһҠбһҫбһҳбҹ’бһ”бһёбһ…бһјбһӣбһҡбһҪбһҳбһҮбҹҶбһҡбһ»бһүбһҖбһ¶бһҡбһўбһ—бһ·бһңбһҢбҹ’бһҚбһҹбҹҒбһҠбҹ’бһӢбһҖбһ·бһ…бҹ’бһ… бһ“бһ·бһ„бһҹбһ„бҹ’бһӮбһҳбҹ”\",\"tag\":\"p\",\"localId\":\"gsbp-5fa756b\",\"styleAttributes\":{\"alignSelf\":[\"center\"],\"justifySelf\":[\"center\"],\"color\":[\"#3b3b3b\"],\"marginTop\":[\"15px\"],\"marginBottom\":[\"0px\"],\"marginLeft\":[\"0px\"],\"marginRight\":[\"0px\"],\"fontSize\":[\"16px\"]}} -->\n<p class=\"gsbp-5fa756b\">бһҮбҹҶбһҡбһ»бһүбһҖбһ¶бһҡбһ—бҹ’бһҮбһ¶бһ”бҹӢбһ бҹҒбһҠбҹ’бһӢбһ¶бһҡбһ…бһ“бһ¶бһҹбһҳбҹ’бһ–бҹҗбһ“бҹ’бһ’ бһ“бһ·бһ„бһҖбһ¶бһҡбһ•бҹ’бһҸбһӣбҹӢбһҹбҹҒбһңбһ¶ бһӣбһҫбһңбһ·бһҹбҹҗбһҷбһ”бҹ’бһҡбҹғбһҹбһҺбһёбһҷбҹҚ бһ“бһ·бһ„бһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚ бһ–бҹ’бһҡбһҳбһ‘бһ¶бҹҶбһ„бһ”бһ…бҹ’бһ…бҹҒбһҖбһңбһ·бһ‘бҹ’бһҷбһ¶бһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚбһ“бһ·бһ„бһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“ бһ“бҹ…бһӮбҹ’бһҡбһ”бҹӢбһ‘бһёбһҖбһ“бҹ’бһӣбҹӮбһ„бһ‘бһ¶бҹҶбһ„бһўбһҹбҹӢбһҖбҹ’бһ“бһ»бһ„бһ”бҹ’бһҡбһ‘бҹҒбһҹбһҖбһҳбҹ’бһ–бһ»бһҮбһ¶ бһ“бҹ…бһҖбҹ’бһ“бһ»бһ„бһҸбҹҶбһ”бһ“бҹӢ бһ“бһ·бһ„бһ–бһ·бһ—бһ–бһӣбҹ„бһҖ бһ”бҹ’бһҡбһҖбһ”бһҠбҹ„бһҷбһӮбһ»бһҺбһ—бһ¶бһ– бһ”бҹ’бһҡбһҹбһ·бһ‘бҹ’бһ’бһ—бһ¶бһ– бһ“бһ·бһ„бһҹбҹҗбһҖбҹ’бһҸбһ·бһҹбһ·бһ‘бҹ’бһ’бһ·бһ—бһ¶бһ–бһҠбһҫбһҳбҹ’бһ”бһёбһ…бһјбһӣбһҡбһҪбһҳбһҮбҹҶбһҡбһ»бһүбһҖбһ¶бһҡбһўбһ—бһ·бһңбһҢбҹ’бһҚбһҹбҹҒбһҠбҹ’бһӢбһҖбһ·бһ…бҹ’бһ… бһ“бһ·бһ„бһҹбһ„бҹ’бһӮбһҳбҹ”</p>\n<!-- /wp:greenshift-blocks/element -->\n\n<!-- wp:greenshift-blocks/element {\"id\":\"gsbp-041848b\",\"textContent\":\"бһ‘бһёбһҖбһ“бҹ’бһӣбҹӮбһ„бһҖбҹҶбһҺбһҫбһҸ\",\"tag\":\"h4\",\"localId\":\"gsbp-041848b\",\"styleAttributes\":{\"color\":[\"#004282\"],\"marginTop\":[\"15px\"],\"marginBottom\":[\"0px\"],\"marginLeft\":[\"0px\"],\"marginRight\":[\"0px\"],\"fontSize\":[\"22px\"]}} -->\n<h4 class=\"gsbp-041848b\">бһ‘бһёбһҖбһ“бҹ’бһӣбҹӮбһ„бһҖбҹҶбһҺбһҫбһҸ</h4>\n<!-- /wp:greenshift-blocks/element -->\n\n<!-- wp:greenshift-blocks/element {\"id\":\"gsbp-1d8e24f\",\"textContent\":\"бҹЎ. бһҠбһ№бһҖбһ“бһ¶бҹҶ бһ“бһ·бһ„бһӮбҹ’бһҡбһ”бҹӢбһӮбҹ’бһҡбһ„бһңбһ·бһҹбҹҗбһҷбһ”бҹ’бһҡбҹғбһҹбһҺбһёбһҷбҹҚ бһ“бһ·бһ„бһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚ бһ–бҹ’бһҡбһҳбһ‘бһ¶бҹҶбһ„бһ”бһ…бҹ’бһ…бҹҒбһҖбһңбһ·бһ‘бҹ’бһҷбһ¶бһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚбһ“бһ·бһ„бһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“ бһҖбҹ’бһ“бһ»бһ„бһ–бҹ’бһҡбҹҮбһҡбһ¶бһҮбһ¶бһҺбһ¶бһ…бһҖбҹ’бһҡбһҖбһҳбҹ’бһ–бһ»бһҮбһ¶ бһҠбҹ„бһҷбһҲбһҡбһӣбһҫбһӮбҹ„бһӣбһҖбһ¶бһҡбһҺбҹҚбһҹбҹҒбһҠбҹ’бһӢбһҖбһ·бһ…бҹ’бһ…бһ‘бһёбһ•бҹ’бһҹбһ¶бһҡбһҹбҹҒбһҡбһё бһ“бһ·бһ„бһҹбһҳбһ’бһҳбҹҢбһҹбһ„бҹ’бһӮбһҳбҹ”\\u003cbr\\u003eбҹў. бһ–бһ„бҹ’бһҡбһёбһҖбһҖбһ¶бһҡбһҖбһҹбһ¶бһ„бһ бҹҒбһҠбҹ’бһӢбһ¶бһҡбһ…бһ“бһ¶бһҹбһҳбҹ’бһ–бҹҗбһ“бҹ’бһ’бһҶбҹ’бһўбһ№бһ„бһҒбҹ’бһ“бһ„бһҡбһ№бһ„бһҳбһ¶бҹҶ бһӣбҹ’бһ”бһҝбһ“бһӣбһҝбһ“ бһҹбһ»бһңбһҸбҹ’бһҗбһ·бһ—бһ¶бһ– бһ“бһ·бһ„бһҮбһҝбһ‘бһ»бһҖбһ…бһ·бһҸбҹ’бһҸ бһұбҹ’бһҷбһ”бһ¶бһ“бһҠбһӣбҹӢбһӮбҹ’бһҡбһ”бҹӢбһ‘бһёбһҖбһ“бҹ’бһӣбҹӮбһ„бһ‘бһ¶бҹҶбһўбһҹбҹӢбһҖбҹ’бһ“бһ»бһ„бһ–бҹ’бһҡбҹҮбһҡбһ¶бһҮбһ¶бһҺбһ¶бһ…бһҖбҹ’бһҡбһҖбһҳбҹ’бһ–бһ»бһҮбһ¶бҹ”\\u003cbr\\u003eбҹЈ. бһўбһ—бһ·бһңбһҢбҹ’бһҚбһңбһ·бһҹбҹҗбһҷбһ”бҹ’бһҡбҹғбһҹбһҺбһёбһҷбҹҚ бһ“бһ·бһ„бһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚ бһ–бҹ’бһҡбһҳбһ‘бһ¶бҹҶбһ„бһ”бһ…бҹ’бһ…бҹҒбһҖбһңбһ·бһ‘бҹ’бһҷбһ¶бһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚбһ“бһ·бһ„бһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“ бһұбҹ’бһҷбһҳбһ¶бһ“бһӣбһҖбҹ’бһҒбһҺбҹҲбһ‘бҹҶбһ“бһҫбһ” бһҳбһ¶бһ“бһӮбһ»бһҺбһ—бһ¶бһ–бһҒбҹ’бһ–бһҹбҹӢ бһҳбһ¶бһ“бһҸбһҳбҹ’бһӣбҹғбһҹбһҳбһҡбһҳбҹ’бһҷ бһ“бһ·бһ„бһҳбһ¶бһ“бһҹбҹҒбһңбһ¶бһӮбҹ’бһҡбһ”бһҠбһҺбҹ’бһҸбһ”бҹӢбһ‘бһјбһ‘бһ¶бҹҶбһ„бһ”бҹ’бһҡбһ‘бҹҒбһҹбһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһ”бҹ’бһҡбһҮбһ¶бһҮбһ“бһ”бҹ’бһҡбһҫбһ”бҹ’бһҡбһ¶бһҹбҹӢ бһ“бһ·бһ„бһ‘бһ‘бһҪбһӣбһ”бһ¶бһ“бһ•бһӣбһ”бҹ’бһҡбһҷбҹ„бһҮбһ“бҹҚбһ–бһёбһҹбҹҒбһңбһ¶бһ“бҹҒбҹҮбҹ”\\u003cbr\\u003eбҹӨ. бһўбһ—бһ·бһңбһҢбҹ’бһҚбһ”бҹ’бһҡбһ–бҹҗбһ“бҹ’бһ’бһҡбһҠбҹ’бһӢбһ¶бһ—бһ·бһ”бһ¶бһӣбһҢбһёбһҮбһёбһҗбһӣбһ“бҹ…бһҗбҹ’бһ“бһ¶бһҖбҹӢбһҮбһ¶бһҸбһ· бһ“бһ·бһ„бһҗбҹ’бһ“бһ¶бһҖбҹӢбһҖбҹ’бһҡбҹ„бһҳбһҮбһ¶бһҸбһ· бһҠбһҫбһҳбҹ’бһ”бһёбһҮбҹҶбһҡбһ»бһүбһҖбһ¶бһҡбһҹбһҳбҹ’бһҡбһ”бһҹбһҳбҹ’бһҡбһҪбһӣбһҖбһ¶бһҡбһӮбҹ’бһҡбһ”бҹӢбһӮбҹ’бһҡбһ„бһҖбһ·бһ…бҹ’бһ…бһҖбһ¶бһҡбһҡбһҠбҹ’бһӢбһ”бһ¶бһӣ бһҡбһңбһ¶бһ„бһҖбҹ’бһҡбһҹбһҪбһ„ бһҹбҹ’бһҗбһ¶бһ”бҹҗбһ“бһҠбҹӮбһӣбһҮбһ¶бһҹбҹҒбһ“бһ¶бһ’бһ·бһҖбһ¶бһҡбһҡбһ”бһҹбҹӢбһҡбһ¶бһҮбһҡбһҠбҹ’бһӢбһ¶бһ—бһ·бһ”бһ¶бһӣ бһ“бһ·бһ„бһҖбһ¶бһҡбһ•бҹ’бһҸбһӣбҹӢбһҹбҹҒбһңбһ¶бһҹбһ¶бһ’бһ¶бһҡбһҺбҹҲбһҮбһјбһ“бһ”бҹ’бһҡбһҮбһ¶бһҮбһ“бһ”бҹ’бһҡбһҖбһ”бһҠбҹ„бһҷбһ—бһ¶бһ–бһҡбһ бҹҗбһҹ бһ”бҹ’бһҡбһҹбһ·бһ‘бҹ’бһ’бһ—бһ¶бһ– бһҸбһҳбҹ’бһӣбһ¶бһ—бһ¶бһ– бһҹбһ»бһңбһҸбҹ’бһҗбһ·бһ—бһ¶бһ– бһҹбһ“бҹ’бһҹбҹҶбһҹбҹҶбһ…бҹғбһҒбҹ’бһ–бһҹбҹӢ бһ“бһ·бһ„бһ…бҹҶбһҺбҹҒбһүбһ–бҹҒбһӣбһңбҹҒбһӣбһ¶бҹ”\\u003cbr\\u003eбҹҘ. бһҮбҹҶбһҡбһ»бһүбһ“бһ·бһ„бһ”бһүбҹ’бһҮбҹ’бһҡбһ¶бһ”бһҖбһ¶бһҡбһҷбһӣбҹӢбһҠбһ№бһ„бһўбҹҶбһ–бһёбһҖбһ¶бһҡбһ”бҹ’бһҡбһҫбһ”бҹ’бһҡбһ¶бһҹбҹӢ бһ“бһ·бһ„бһ•бһӣбһ”бҹ’бһҡбһҷбҹ„бһҮбһ“бҹҚбһ“бҹғбһ”бһ…бҹ’бһ…бҹҒбһҖбһңбһ·бһ‘бҹ’бһҷбһ¶бһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚбһ“бһ·бһ„бһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“ бһҸбһ¶бһҳбһҡбһҷбҹҲбһҖбһ¶бһҡбһ•бҹ’бһҹбһ–бҹ’бһңбһ•бҹ’бһҹбһ¶бһҷбһұбҹ’бһҷбһ”бһ¶бһ“бһ‘бһјбһӣбҹҶбһ‘бһјбһӣбһ¶бһҷ бһҖбһ¶бһҡбһ”бһҺбҹ’бһҸбһ»бҹҮбһ”бһҺбҹ’бһҸбһ¶бһӣбһ“бһ·бһ„бһҖбһ¶бһҡбһҖбһҹбһ¶бһ„бһҹбһҳбһҸбҹ’бһҗбһ—бһ¶бһ–бһҳбһ“бҹ’бһҸбҹ’бһҡбһёбһҡбһ¶бһҮбһҖбһ¶бһҡ бһҹбһ·бһҹбҹ’бһҹ бһ“бһ·бһҹбҹ’бһҹбһ·бһҸ бһҡбһҪбһҳбһ‘бһ¶бҹҶбһ„бһңбһ·бһҹбҹҗбһҷбһҜбһҖбһҮбһ“бҹ”\\u003cbr\\u003eбҹҰ. бһӣбһҫбһҖбһ‘бһ№бһҖбһ…бһ·бһҸбҹ’бһҸбһңбһ·бһ“бһ·бһҷбҹ„бһӮбһ·бһ“бһҖбҹ’бһ“бһ»бһ„бһҖбһ¶бһҡбһ’бҹ’бһңбһҫбһ‘бҹҶбһ“бһҫбһ”бһҖбһҳбҹ’бһҳбһңбһ·бһҹбҹҗбһҷбһ”бҹ’бһҡбҹғбһҹбһҺбһёбһҷбҹҚ бһ“бһ·бһ„бһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚ бһ–бҹ’бһҡбһҳбһ‘бһ¶бҹҶбһ„бһ”бһ…бҹ’бһ…бҹҒбһҖбһңбһ·бһ‘бҹ’бһҷбһ¶бһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚбһ“бһ·бһ„бһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“ бһ“бһ·бһ„бһ’бҹ’бһңбһҫбһҖбһ¶бһҡбһҡбҹҖбһ”бһ…бҹҶбһўбһ—бһ·бһҖбҹ’бһҡбһҳ бһҠбһҫбһҳбҹ’бһ”бһёбһӣбһҫбһҖбһҖбһҳбҹ’бһ–бһҹбҹӢбһҖбһ¶бһҡбһҹбҹ’бһҡбһ¶бһңбһҮбҹ’бһҡбһ¶бһң бһ“бһ·бһ„бһўбһ—бһ·бһңбһҢбҹ’бһҚбһӣбһҫбһңбһ·бһҹбҹҗбһҷбһ”бҹ’бһҡбҹғбһҹбһҺбһёбһҷбҹҚ бһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚ бһ“бһ·бһ„бһ”бһ…бҹ’бһ…бҹҒбһҖбһңбһ·бһ‘бҹ’бһҷбһ¶бһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚбһ“бһ·бһ„бһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“бҹ”\\u003cbr\\u003eбҹ§. бһҮбҹҶбһҡбһ»бһүбһ”бҹ’бһҡбһҸбһ·бһ”бһҸбҹ’бһҸбһ·бһҖбһҡбһңбһ·бһҹбҹҗбһҷбһ”бҹ’бһҡбҹғбһҹбһҺбһёбһҷбҹҚ бһ“бһ·бһ„бһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚ бһ–бҹ’бһҡбһҳбһ‘бһ¶бҹҶбһ„бһ”бһ…бҹ’бһ…бҹҒбһҖбһңбһ·бһ‘бҹ’бһҷбһ¶бһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚбһ“бһ·бһ„бһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“ бһўбһ“бһ»бһңбһҸбҹ’бһҸбһҹбһ·бһ‘бҹ’бһ’бһ· бһ“бһ·бһ„бһҖбһ¶бһҸбһ–бҹ’бһңбһҖбһ·бһ…бҹ’бһ… бһҹбҹ’бһҡбһ”бһҸбһ¶бһҳбһ…бҹ’бһ”бһ¶бһ”бҹӢ бһ“бһ·бһ„бһӣбһ·бһҒбһ·бһҸбһ”бһ‘бһҠбҹ’бһӢбһ¶бһ“бһӮбһҸбһ·бһҷбһ»бһҸбҹ’бһҸбһҮбһ¶бһ’бһҡбһҳбһ¶бһ“ бһҠбһҫбһҳбҹ’бһ”бһёбһ’бһ¶бһ“бһ¶бһҖбһ¶бһҡбһ”бҹ’бһҡбһҖбһҪбһҸбһ”бҹ’бһҡбһҮбҹӮбһ„бһҠбҹ„бһҷбһҹбҹ’бһҡбһ”бһ…бҹ’бһ”бһ¶бһ”бҹӢ бһ“бһ·бһ„бһҹбҹ’бһҳбҹ„бҹҮбһҸбҹ’бһҡбһ„бҹӢ бһ“бһ·бһ„бһҠбһҫбһҳбҹ’бһ”бһёбһҖбһ¶бһҡбһ–бһ¶бһҡбһҹбһ·бһ‘бҹ’бһ’бһ·бһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖбһ”бҹ’бһҡбһҫбһ”бҹ’бһҡбһ¶бһҹбҹӢбҹ”\",\"tag\":\"p\",\"localId\":\"gsbp-1d8e24f\",\"styleAttributes\":{\"alignSelf\":[\"center\"],\"justifySelf\":[\"center\"],\"color\":[\"#3b3b3b\"],\"marginTop\":[\"15px\"],\"marginBottom\":[\"0px\"],\"marginLeft\":[\"0px\"],\"marginRight\":[\"0px\"],\"fontSize\":[\"16px\"]}} -->\n<p class=\"gsbp-1d8e24f\">бҹЎ. бһҠбһ№бһҖбһ“бһ¶бҹҶ бһ“бһ·бһ„бһӮбҹ’бһҡбһ”бҹӢбһӮбҹ’бһҡбһ„бһңбһ·бһҹбҹҗбһҷбһ”бҹ’бһҡбҹғбһҹбһҺбһёбһҷбҹҚ бһ“бһ·бһ„бһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚ бһ–бҹ’бһҡбһҳбһ‘бһ¶бҹҶбһ„бһ”бһ…бҹ’бһ…бҹҒбһҖбһңбһ·бһ‘бҹ’бһҷбһ¶бһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚбһ“бһ·бһ„бһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“ бһҖбҹ’бһ“бһ»бһ„бһ–бҹ’бһҡбҹҮбһҡбһ¶бһҮбһ¶бһҺбһ¶бһ…бһҖбҹ’бһҡбһҖбһҳбҹ’бһ–бһ»бһҮбһ¶ бһҠбҹ„бһҷбһҲбһҡбһӣбһҫбһӮбҹ„бһӣбһҖбһ¶бһҡбһҺбҹҚбһҹбҹҒбһҠбҹ’бһӢбһҖбһ·бһ…бҹ’бһ…бһ‘бһёбһ•бҹ’бһҹбһ¶бһҡбһҹбҹҒбһҡбһё бһ“бһ·бһ„бһҹбһҳбһ’бһҳбҹҢбһҹбһ„бҹ’бһӮбһҳбҹ”<br>бҹў. бһ–бһ„бҹ’бһҡбһёбһҖбһҖбһ¶бһҡбһҖбһҹбһ¶бһ„бһ бҹҒбһҠбҹ’бһӢбһ¶бһҡбһ…бһ“бһ¶бһҹбһҳбҹ’бһ–бҹҗбһ“бҹ’бһ’бһҶбҹ’бһўбһ№бһ„бһҒбҹ’бһ“бһ„бһҡбһ№бһ„бһҳбһ¶бҹҶ бһӣбҹ’бһ”бһҝбһ“бһӣбһҝбһ“ бһҹбһ»бһңбһҸбҹ’бһҗбһ·бһ—бһ¶бһ– бһ“бһ·бһ„бһҮбһҝбһ‘бһ»бһҖбһ…бһ·бһҸбҹ’бһҸ бһұбҹ’бһҷбһ”бһ¶бһ“бһҠбһӣбҹӢбһӮбҹ’бһҡбһ”бҹӢбһ‘бһёбһҖбһ“бҹ’бһӣбҹӮбһ„бһ‘бһ¶бҹҶбһўбһҹбҹӢбһҖбҹ’бһ“бһ»бһ„бһ–бҹ’бһҡбҹҮбһҡбһ¶бһҮбһ¶бһҺбһ¶бһ…бһҖбҹ’бһҡбһҖбһҳбҹ’бһ–бһ»бһҮбһ¶бҹ”<br>бҹЈ. бһўбһ—бһ·бһңбһҢбҹ’бһҚбһңбһ·бһҹбҹҗбһҷбһ”бҹ’бһҡбҹғбһҹбһҺбһёбһҷбҹҚ бһ“бһ·бһ„бһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚ бһ–бҹ’бһҡбһҳбһ‘бһ¶бҹҶбһ„бһ”бһ…бҹ’бһ…бҹҒбһҖбһңбһ·бһ‘бҹ’бһҷбһ¶бһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚбһ“бһ·бһ„бһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“ бһұбҹ’бһҷбһҳбһ¶бһ“бһӣбһҖбҹ’бһҒбһҺбҹҲбһ‘бҹҶбһ“бһҫбһ” бһҳбһ¶бһ“бһӮбһ»бһҺбһ—бһ¶бһ–бһҒбҹ’бһ–бһҹбҹӢ бһҳбһ¶бһ“бһҸбһҳбҹ’бһӣбҹғбһҹбһҳбһҡбһҳбҹ’бһҷ бһ“бһ·бһ„бһҳбһ¶бһ“бһҹбҹҒбһңбһ¶бһӮбҹ’бһҡбһ”бһҠбһҺбҹ’бһҸбһ”бҹӢбһ‘бһјбһ‘бһ¶бҹҶбһ„бһ”бҹ’бһҡбһ‘бҹҒбһҹбһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһ”бҹ’бһҡбһҮбһ¶бһҮбһ“бһ”бҹ’бһҡбһҫбһ”бҹ’бһҡбһ¶бһҹбҹӢ бһ“бһ·бһ„бһ‘бһ‘бһҪбһӣбһ”бһ¶бһ“бһ•бһӣбһ”бҹ’бһҡбһҷбҹ„бһҮбһ“бҹҚбһ–бһёбһҹбҹҒбһңбһ¶бһ“бҹҒбҹҮбҹ”<br>бҹӨ. бһўбһ—бһ·бһңбһҢбҹ’бһҚбһ”бҹ’бһҡбһ–бҹҗбһ“бҹ’бһ’бһҡбһҠбҹ’бһӢбһ¶бһ—бһ·бһ”бһ¶бһӣбһҢбһёбһҮбһёбһҗбһӣбһ“бҹ…бһҗбҹ’бһ“бһ¶бһҖбҹӢбһҮбһ¶бһҸбһ· бһ“бһ·бһ„бһҗбҹ’бһ“бһ¶бһҖбҹӢбһҖбҹ’бһҡбҹ„бһҳбһҮбһ¶бһҸбһ· бһҠбһҫбһҳбҹ’бһ”бһёбһҮбҹҶбһҡбһ»бһүбһҖбһ¶бһҡбһҹбһҳбҹ’бһҡбһ”бһҹбһҳбҹ’бһҡбһҪбһӣбһҖбһ¶бһҡбһӮбҹ’бһҡбһ”бҹӢбһӮбҹ’бһҡбһ„бһҖбһ·бһ…бҹ’бһ…бһҖбһ¶бһҡбһҡбһҠбҹ’бһӢбһ”бһ¶бһӣ бһҡбһңбһ¶бһ„бһҖбҹ’бһҡбһҹбһҪбһ„ бһҹбҹ’бһҗбһ¶бһ”бҹҗбһ“бһҠбҹӮбһӣбһҮбһ¶бһҹбҹҒбһ“бһ¶бһ’бһ·бһҖбһ¶бһҡбһҡбһ”бһҹбҹӢбһҡбһ¶бһҮбһҡбһҠбҹ’бһӢбһ¶бһ—бһ·бһ”бһ¶бһӣ бһ“бһ·бһ„бһҖбһ¶бһҡбһ•бҹ’бһҸбһӣбҹӢбһҹбҹҒбһңбһ¶бһҹбһ¶бһ’бһ¶бһҡбһҺбҹҲбһҮбһјбһ“бһ”бҹ’бһҡбһҮбһ¶бһҮбһ“бһ”бҹ’бһҡбһҖбһ”бһҠбҹ„бһҷбһ—бһ¶бһ–бһҡбһ бҹҗбһҹ бһ”бҹ’бһҡбһҹбһ·бһ‘бҹ’бһ’бһ—бһ¶бһ– бһҸбһҳбҹ’бһӣбһ¶бһ—бһ¶бһ– бһҹбһ»бһңбһҸбҹ’бһҗбһ·бһ—бһ¶бһ– бһҹбһ“бҹ’бһҹбҹҶбһҹбҹҶбһ…бҹғбһҒбҹ’бһ–бһҹбҹӢ бһ“бһ·бһ„бһ…бҹҶбһҺбҹҒбһүбһ–бҹҒбһӣбһңбҹҒбһӣбһ¶бҹ”<br>бҹҘ. бһҮбҹҶбһҡбһ»бһүбһ“бһ·бһ„бһ”бһүбҹ’бһҮбҹ’бһҡбһ¶бһ”бһҖбһ¶бһҡбһҷбһӣбҹӢбһҠбһ№бһ„бһўбҹҶбһ–бһёбһҖбһ¶бһҡбһ”бҹ’бһҡбһҫбһ”бҹ’бһҡбһ¶бһҹбҹӢ бһ“бһ·бһ„бһ•бһӣбһ”бҹ’бһҡбһҷбҹ„бһҮбһ“бҹҚбһ“бҹғбһ”бһ…бҹ’бһ…бҹҒбһҖбһңбһ·бһ‘бҹ’бһҷбһ¶бһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚбһ“бһ·бһ„бһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“ бһҸбһ¶бһҳбһҡбһҷбҹҲбһҖбһ¶бһҡбһ•бҹ’бһҹбһ–бҹ’бһңбһ•бҹ’бһҹбһ¶бһҷбһұбҹ’бһҷбһ”бһ¶бһ“бһ‘бһјбһӣбҹҶбһ‘бһјбһӣбһ¶бһҷ бһҖбһ¶бһҡбһ”бһҺбҹ’бһҸбһ»бҹҮбһ”бһҺбҹ’бһҸбһ¶бһӣбһ“бһ·бһ„бһҖбһ¶бһҡбһҖбһҹбһ¶бһ„бһҹбһҳбһҸбҹ’бһҗбһ—бһ¶бһ–бһҳбһ“бҹ’бһҸбҹ’бһҡбһёбһҡбһ¶бһҮбһҖбһ¶бһҡ бһҹбһ·бһҹбҹ’бһҹ бһ“бһ·бһҹбҹ’бһҹбһ·бһҸ бһҡбһҪбһҳбһ‘бһ¶бҹҶбһ„бһңбһ·бһҹбҹҗбһҷбһҜбһҖбһҮбһ“бҹ”<br>бҹҰ. бһӣбһҫбһҖбһ‘бһ№бһҖбһ…бһ·бһҸбҹ’бһҸбһңбһ·бһ“бһ·бһҷбҹ„бһӮбһ·бһ“бһҖбҹ’бһ“бһ»бһ„бһҖбһ¶бһҡбһ’бҹ’бһңбһҫбһ‘бҹҶбһ“бһҫбһ”бһҖбһҳбҹ’бһҳбһңбһ·бһҹбҹҗбһҷбһ”бҹ’бһҡбҹғбһҹбһҺбһёбһҷбҹҚ бһ“бһ·бһ„бһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚ бһ–бҹ’бһҡбһҳбһ‘бһ¶бҹҶбһ„бһ”бһ…бҹ’бһ…бҹҒбһҖбһңбһ·бһ‘бҹ’бһҷбһ¶бһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚбһ“бһ·бһ„бһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“ бһ“бһ·бһ„бһ’бҹ’бһңбһҫбһҖбһ¶бһҡбһҡбҹҖбһ”бһ…бҹҶбһўбһ—бһ·бһҖбҹ’бһҡбһҳ бһҠбһҫбһҳбҹ’бһ”бһёбһӣбһҫбһҖбһҖбһҳбҹ’бһ–бһҹбҹӢбһҖбһ¶бһҡбһҹбҹ’бһҡбһ¶бһңбһҮбҹ’бһҡбһ¶бһң бһ“бһ·бһ„бһўбһ—бһ·бһңбһҢбҹ’бһҚбһӣбһҫбһңбһ·бһҹбҹҗбһҷбһ”бҹ’бһҡбҹғбһҹбһҺбһёбһҷбҹҚ бһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚ бһ“бһ·бһ„бһ”бһ…бҹ’бһ…бҹҒбһҖбһңбһ·бһ‘бҹ’бһҷбһ¶бһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚбһ“бһ·бһ„бһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“бҹ”<br>бҹ§. бһҮбҹҶбһҡбһ»бһүбһ”бҹ’бһҡбһҸбһ·бһ”бһҸбҹ’бһҸбһ·бһҖбһҡбһңбһ·бһҹбҹҗбһҷбһ”бҹ’бһҡбҹғбһҹбһҺбһёбһҷбҹҚ бһ“бһ·бһ„бһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚ бһ–бҹ’бһҡбһҳбһ‘бһ¶бҹҶбһ„бһ”бһ…бҹ’бһ…бҹҒбһҖбһңбһ·бһ‘бҹ’бһҷбһ¶бһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚбһ“бһ·бһ„бһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“ бһўбһ“бһ»бһңбһҸбҹ’бһҸбһҹбһ·бһ‘бҹ’бһ’бһ· бһ“бһ·бһ„бһҖбһ¶бһҸбһ–бҹ’бһңбһҖбһ·бһ…бҹ’бһ… бһҹбҹ’бһҡбһ”бһҸбһ¶бһҳбһ…бҹ’бһ”бһ¶бһ”бҹӢ бһ“бһ·бһ„бһӣбһ·бһҒбһ·бһҸбһ”бһ‘бһҠбҹ’бһӢбһ¶бһ“бһӮбһҸбһ·бһҷбһ»бһҸбҹ’бһҸбһҮбһ¶бһ’бһҡбһҳбһ¶бһ“ бһҠбһҫбһҳбҹ’бһ”бһёбһ’бһ¶бһ“бһ¶бһҖбһ¶бһҡбһ”бҹ’бһҡбһҖбһҪбһҸбһ”бҹ’бһҡбһҮбҹӮбһ„бһҠбҹ„бһҷбһҹбҹ’бһҡбһ”бһ…бҹ’бһ”бһ¶бһ”бҹӢ бһ“бһ·бһ„бһҹбҹ’бһҳбҹ„бҹҮбһҸбҹ’бһҡбһ„бҹӢ бһ“бһ·бһ„бһҠбһҫбһҳбҹ’бһ”бһёбһҖбһ¶бһҡбһ–бһ¶бһҡбһҹбһ·бһ‘бҹ’бһ’бһ·бһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖбһ”бҹ’бһҡбһҫбһ”бҹ’бһҡбһ¶бһҹбҹӢбҹ”</p>\n<!-- /wp:greenshift-blocks/element -->\n\n<!-- wp:greenshift-blocks/element {\"id\":\"gsbp-e4929c8\",\"textContent\":\"\\u003cstrong\\u003eбһӮбһ»бһҺбһҸбһҳбҹ’бһӣбҹғбҹ– бһ”бҹ’бһҡбһҹбһ·бһ‘бҹ’бһ’бһ—бһ¶бһ– бһҸбһҳбҹ’бһӣбһ¶бһ—бһ¶бһ– бһ“бһ·бһ„бһҹбһҳбһ’бһҳбҹҢ\\u003c/strong\\u003e\",\"tag\":\"h4\",\"localId\":\"gsbp-e4929c8\",\"styleAttributes\":{\"color\":[\"#cf2e2e\"],\"marginTop\":[\"15px\"],\"marginBottom\":[\"0px\"],\"marginLeft\":[\"0px\"],\"marginRight\":[\"0px\"]}} -->\n<h4 class=\"gsbp-e4929c8\"><strong>бһӮбһ»бһҺбһҸбһҳбҹ’бһӣбҹғбҹ– бһ”бҹ’бһҡбһҹбһ·бһ‘бҹ’бһ’бһ—бһ¶бһ– бһҸбһҳбҹ’бһӣбһ¶бһ—бһ¶бһ– бһ“бһ·бһ„бһҹбһҳбһ’бһҳбҹҢ</strong></h4>\n<!-- /wp:greenshift-blocks/element -->\n\n<!-- wp:greenshift-blocks/element {\"id\":\"gsbp-9470b96\",\"textContent\":\"бһ”бһ¶бһңбһ…бһ“бһ¶\",\"tag\":\"h4\",\"localId\":\"gsbp-9470b96\",\"styleAttributes\":{\"color\":[\"#004282\"],\"marginTop\":[\"15px\"],\"marginBottom\":[\"0px\"],\"marginLeft\":[\"0px\"],\"marginRight\":[\"0px\"],\"fontSize\":[\"22px\"]}} -->\n<h4 class=\"gsbp-9470b96\">бһ”бһ¶бһңбһ…бһ“бһ¶</h4>\n<!-- /wp:greenshift-blocks/element -->\n\n<!-- wp:greenshift-blocks/element {\"id\":\"gsbp-001ae6f\",\"textContent\":\"\\u003cstrong\\u003e\\u003cstrong\\u003eбһҹбһ“бҹ’бһ’бһ·бһҖбһҖбһҳбҹ’бһ–бһ»бһҮбһ¶\\u003c/strong\\u003e\\u003c/strong\\u003e\",\"tag\":\"h4\",\"localId\":\"gsbp-001ae6f\",\"styleAttributes\":{\"color\":[\"#cf2e2e\"],\"marginTop\":[\"15px\"],\"marginBottom\":[\"0px\"],\"marginLeft\":[\"0px\"],\"marginRight\":[\"0px\"]}} -->\n<h4 class=\"gsbp-001ae6f\"><strong><strong>бһҹбһ“бҹ’бһ’бһ·бһҖбһҖбһҳбҹ’бһ–бһ»бһҮбһ¶</strong></strong></h4>\n<!-- /wp:greenshift-blocks/element -->\n\n<!-- wp:greenshift-blocks/element {\"id\":\"gsbp-df1b7e2\",\"textContent\":\"бһҡбһјбһ”бһҹбһүбҹ’бһүбһ¶бһҳбһ¶бһ“бһҡбһ¶бһ„бһҳбһјбһӣ бһҳбһ¶бһ“бһўбһ„бҹ’бһҖбһҸбҹӢбһ•бҹ’бһ…бһ·бһҸбһ”бҹ’бһҡбһңбҹӮбһ„ бҹЈ бһҹбһ„бҹӢбһ‘бһёбһҳбҹүбҹӮбһҸбҹ’бһҡ\",\"tag\":\"p\",\"localId\":\"gsbp-df1b7e2\",\"styleAttributes\":{\"alignSelf\":[\"\"],\"justifySelf\":[\"\"],\"color\":[\"#3b3b3b\"],\"marginTop\":[\"15px\"],\"marginBottom\":[\"0px\"],\"marginLeft\":[\"0px\"],\"marginRight\":[\"0px\"],\"fontSize\":[\"16px\"]}} -->\n<p class=\"gsbp-df1b7e2\">бһҡбһјбһ”бһҹбһүбҹ’бһүбһ¶бһҳбһ¶бһ“бһҡбһ¶бһ„бһҳбһјбһӣ бһҳбһ¶бһ“бһўбһ„бҹ’бһҖбһҸбҹӢбһ•бҹ’бһ…бһ·бһҸбһ”бҹ’бһҡбһңбҹӮбһ„ бҹЈ бһҹбһ„бҹӢбһ‘бһёбһҳбҹүбҹӮбһҸбҹ’бһҡ</p>\n<!-- /wp:greenshift-blocks/element -->\n\n<!-- wp:greenshift-blocks/element {\"id\":\"gsbp-7ccfb1f\",\"textContent\":\"бһ“бҹ…бһҖбҹ’бһ“бһ»бһ„бһ•бҹ’бһ‘бҹғбһҡбһ„бҹ’бһңбһ„бҹӢбһҳбһ¶бһ“бҹ–\",\"tag\":\"p\",\"localId\":\"gsbp-7ccfb1f\",\"styleAttributes\":{\"alignSelf\":[\"\"],\"justifySelf\":[\"\"],\"color\":[\"#3b3b3b\"],\"marginTop\":[\"15px\"],\"marginBottom\":[\"0px\"],\"marginLeft\":[\"0px\"],\"marginRight\":[\"0px\"],\"fontSize\":[\"16px\"]}} -->\n<p class=\"gsbp-7ccfb1f\">бһ“бҹ…бһҖбҹ’бһ“бһ»бһ„бһ•бҹ’бһ‘бҹғбһҡбһ„бҹ’бһңбһ„бҹӢбһҳбһ¶бһ“бҹ–</p>\n<!-- /wp:greenshift-blocks/element -->\n\n<!-- wp:greenshift-blocks/element {\"id\":\"gsbp-da9d360\",\"textContent\":\"бһҒбҹ’бһҹбҹӮбһ”бҹ’бһҡбһ¶бҹҶбһ–бһҺбҹҢбһҖбҹ’бһҡбһ бһҳбһ“бҹғбһ–бһ¶бһҖбҹӢбһҖбһҺбҹ’бһҠбһ¶бһӣбһҡбһ„бҹ’бһңбһ„бҹӢбһҒбһ¶бһ„бһӣбһҫ бһӮбһәбһҸбҹҶбһҺбһ¶бһ„бһұбҹ’бһҷбһ‘бҹ’бһңбһёбһ” бһ‘бһ¶бҹҶбһ„бһ”бҹ’бһҡбһ¶бҹҶ бһҹбһүбҹ’бһүбһ¶бһҖбһ„бһ…бһҖбҹ’бһҡ бһ–бһҺбҹҢбһҒбҹҖбһң бһ“бҹғбһ–бһ¶бһҖбҹӢбһҖбһҺбҹ’бһҠбһ¶бһӣбһҡбһ„бҹ’бһңбһ„бҹӢбһҒбһ¶бһ„бһҖбҹ’бһҡбҹ„бһҳ бһ…бҹҶбһ“бһҪбһ“ бһ”бҹ’бһҡбһ¶бҹҶбһ–бһёбһҡбһҖбһ¶бҹҶ бһӮбһәбһҸбҹҶбһҺбһ¶бһ„бһұбҹ’бһҷбһҳбһ“бҹ’бһҸбҹ’бһҡбһёбһҡбһ¶бһҮбһҖбһ¶бһҡ бһҒбҹ’бһҹбҹӮбһ”бһ“бҹ’бһ‘бһ¶бһҸбҹӢбһ–бһҺбҹҢбһҹ бһҒбһ¶бһ„бһҖбҹ’бһ“бһ»бһ„бһҠбҹӮбһӣбһ”бҹ’бһҡбһ‘бһ¶бһҖбҹӢбһӮбҹ’бһ“бһ¶бһӣбһҫбһ•бҹӮбһ“бһҠбһёбһ–бһҺбҹҢбһ•бҹ’бһ‘бҹғбһҳбҹҒбһғ бһӮбһә бһҸбҹҶбһҺбһ¶бһ„бһұбҹ’бһҷбһ”бҹ’бһҡбһ–бҹҗбһ“бҹ’бһ’бһ‘бҹҶбһ“бһ¶бһҖбҹӢбһ‘бҹҶбһ“бһ„бһҡбһ”бһҹбҹӢбһңбһ·бһҹбҹҗбһҷбһ”бҹ’бһҡбҹғбһҹбһҺбһёбһҷбҹҚ бһ“бһ·бһ„бһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚбһӣбһҫбһ–бһ·бһ—бһ–бһӣбҹ„бһҖ бһҹбһүбҹ’бһүбһ¶бһҖбһ¶бҹҶбһ•бҹ’бһӣбҹҒбһҖбһ”бһ“бҹ’бһ‘бҹ„бһӣбһ–бһҺбҹҢбһӣбһҝбһ„бһ‘бһ»бҹҶ бһӮбһәбһҸбҹҶбһҺбһ¶бһ„бһұбҹ’бһҷбһҡбһӣбһҖбһўбһ¶бһҖбһ¶бһҹбһңбһ·бһ‘бҹ’бһҷбһ» бһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚ бһўбһҖбҹ’бһҹбһҡбһ–бһҺбҹҢбһҹ бһҠбҹӮбһӣбһҹбҹ’бһҗбһ·бһ“бһ“бҹ…бһӣбһҫбһ“бҹғбһ•бҹӮбһ“бһҠбһё бһҠбҹӮбһӣбһҹбһҡбһҹбҹҒбһҡбһўбһҖбҹ’бһҹбһҡбһҖбһ¶бһҸбҹӢ бһ”.бһ‘.бһҖ бһҳбһ¶бһ“бһ“бҹҗбһҷ бһ”бҹ’бһҡбҹғбһҹбһҺбһёбһҷбҹҚ бһ“бһ·бһ„бһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚбһҖбһҳбҹ’бһ–бһ»бһҮбһ¶ бһўбһҖбҹ’бһҹбһҡбһЎбһ¶бһҸбһ¶бҹҶбһ„бһ–бһҺбҹҢбһҹ бһ“бҹ…бһ•бҹ’бһ“бҹӮбһҖбһҒбһ¶бһ„бһҖбҹ’бһҡбҹ„бһҳбһ“бҹғбһ•бҹӮбһ“бһҠбһё бһҠбҹӮбһӣбһҹбһҡбһҹбҹҒбһҡбһўбһҖбҹ’бһҹбһҡ бһҖбһ¶бһҸбҹӢ P.T.C бһҳбһ¶бһ“бһ“бҹҗбһҷбһҗбһ¶ Post and Telecommunication of CambodiaвҖқ бҹ”\",\"tag\":\"p\",\"localId\":\"gsbp-da9d360\",\"styleAttributes\":{\"alignSelf\":[\"\"],\"justifySelf\":[\"\"],\"color\":[\"#3b3b3b\"],\"marginTop\":[\"15px\"],\"marginBottom\":[\"0px\"],\"marginLeft\":[\"0px\"],\"marginRight\":[\"0px\"],\"fontSize\":[\"16px\"]}} -->\n<p class=\"gsbp-da9d360\">бһҒбҹ’бһҹбҹӮбһ”бҹ’бһҡбһ¶бҹҶбһ–бһҺбҹҢбһҖбҹ’бһҡбһ бһҳбһ“бҹғбһ–бһ¶бһҖбҹӢбһҖбһҺбҹ’бһҠбһ¶бһӣбһҡбһ„бҹ’бһңбһ„бҹӢбһҒбһ¶бһ„бһӣбһҫ бһӮбһәбһҸбҹҶбһҺбһ¶бһ„бһұбҹ’бһҷбһ‘бҹ’бһңбһёбһ” бһ‘бһ¶бҹҶбһ„бһ”бҹ’бһҡбһ¶бҹҶ бһҹбһүбҹ’бһүбһ¶бһҖбһ„бһ…бһҖбҹ’бһҡ бһ–бһҺбҹҢбһҒбҹҖбһң бһ“бҹғбһ–бһ¶бһҖбҹӢбһҖбһҺбҹ’бһҠбһ¶бһӣбһҡбһ„бҹ’бһңбһ„бҹӢбһҒбһ¶бһ„бһҖбҹ’бһҡбҹ„бһҳ бһ…бҹҶбһ“бһҪбһ“ бһ”бҹ’бһҡбһ¶бҹҶбһ–бһёбһҡбһҖбһ¶бҹҶ бһӮбһәбһҸбҹҶбһҺбһ¶бһ„бһұбҹ’бһҷбһҳбһ“бҹ’бһҸбҹ’бһҡбһёбһҡбһ¶бһҮбһҖбһ¶бһҡ бһҒбҹ’бһҹбҹӮбһ”бһ“бҹ’бһ‘бһ¶бһҸбҹӢбһ–бһҺбҹҢбһҹ бһҒбһ¶бһ„бһҖбҹ’бһ“бһ»бһ„бһҠбҹӮбһӣбһ”бҹ’бһҡбһ‘бһ¶бһҖбҹӢбһӮбҹ’бһ“бһ¶бһӣбһҫбһ•бҹӮбһ“бһҠбһёбһ–бһҺбҹҢбһ•бҹ’бһ‘бҹғбһҳбҹҒбһғ бһӮбһә бһҸбҹҶбһҺбһ¶бһ„бһұбҹ’бһҷбһ”бҹ’бһҡбһ–бҹҗбһ“бҹ’бһ’бһ‘бҹҶбһ“бһ¶бһҖбҹӢбһ‘бҹҶбһ“бһ„бһҡбһ”бһҹбҹӢбһңбһ·бһҹбҹҗбһҷбһ”бҹ’бһҡбҹғбһҹбһҺбһёбһҷбҹҚ бһ“бһ·бһ„бһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚбһӣбһҫбһ–бһ·бһ—бһ–бһӣбҹ„бһҖ бһҹбһүбҹ’бһүбһ¶бһҖбһ¶бҹҶбһ•бҹ’бһӣбҹҒбһҖбһ”бһ“бҹ’бһ‘бҹ„бһӣбһ–бһҺбҹҢбһӣбһҝбһ„бһ‘бһ»бҹҶ бһӮбһәбһҸбҹҶбһҺбһ¶бһ„бһұбҹ’бһҷбһҡбһӣбһҖбһўбһ¶бһҖбһ¶бһҹбһңбһ·бһ‘бҹ’бһҷбһ» бһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚ бһўбһҖбҹ’бһҹбһҡбһ–бһҺбҹҢбһҹ бһҠбҹӮбһӣбһҹбҹ’бһҗбһ·бһ“бһ“бҹ…бһӣбһҫбһ“бҹғбһ•бҹӮбһ“бһҠбһё бһҠбҹӮбһӣбһҹбһҡбһҹбҹҒбһҡбһўбһҖбҹ’бһҹбһҡбһҖбһ¶бһҸбҹӢ бһ”.бһ‘.бһҖ бһҳбһ¶бһ“бһ“бҹҗбһҷ бһ”бҹ’бһҡбҹғбһҹбһҺбһёбһҷбҹҚ бһ“бһ·бһ„бһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚбһҖбһҳбҹ’бһ–бһ»бһҮбһ¶ бһўбһҖбҹ’бһҹбһҡбһЎбһ¶бһҸбһ¶бҹҶбһ„бһ–бһҺбҹҢбһҹ бһ“бҹ…бһ•бҹ’бһ“бҹӮбһҖбһҒбһ¶бһ„бһҖбҹ’бһҡбҹ„бһҳбһ“бҹғбһ•бҹӮбһ“бһҠбһё бһҠбҹӮбһӣбһҹбһҡбһҹбҹҒбһҡбһўбһҖбҹ’бһҹбһҡ бһҖбһ¶бһҸбҹӢ P.T.C бһҳбһ¶бһ“бһ“бҹҗбһҷбһҗбһ¶ Post and Telecommunication of CambodiaвҖқ бҹ”</p>\n<!-- /wp:greenshift-blocks/element -->\n\n<!-- wp:greenshift-blocks/element {\"id\":\"gsbp-3c9e93c\",\"textContent\":\"бһҡбһјбһ”бһҹбһүбҹ’бһүбһ¶бһҖбҹ’бһҡбһҹбһҪбһ„бһ”бҹ’бһҡбҹғбһҹбһҺбһёбһҷбҹҚбһ“бһ·бһ„бһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚ\",\"tag\":\"p\",\"localId\":\"gsbp-3c9e93c\",\"styleAttributes\":{\"alignSelf\":[\"\"],\"justifySelf\":[\"center\"],\"color\":[\"#3b3b3b\"],\"marginTop\":[\"24px\"],\"marginBottom\":[\"0px\"],\"marginLeft\":[\"0px\"],\"marginRight\":[\"0px\"],\"fontSize\":[\"var(\\u002d\\u002dwp\\u002d\\u002dpreset\\u002d\\u002dfont-size\\u002d\\u002dxl, clamp(1.6rem, 2.75vw, 1.9rem))\"],\"lineHeight\":[\"var(\\u002d\\u002dwp\\u002d\\u002dcustom\\u002d\\u002dline-height\\u002d\\u002dxl, clamp(2.3rem, 3.45vw, 2.6rem))\"]}} -->\n<p class=\"gsbp-3c9e93c\">бһҡбһјбһ”бһҹбһүбҹ’бһүбһ¶бһҖбҹ’бһҡбһҹбһҪбһ„бһ”бҹ’бһҡбҹғбһҹбһҺбһёбһҷбҹҚбһ“бһ·бһ„бһ‘бһјбһҡбһӮбһҳбһ“бһ¶бһӮбһҳбһ“бҹҚ</p>\n<!-- /wp:greenshift-blocks/element -->\n\n<!-- wp:greenshift-blocks/element {\"id\":\"gsbp-a15549e\",\"type\":\"inner\",\"localId\":\"gsbp-a15549e\",\"styleAttributes\":{\"justifySelf\":[\"center\"],\"marginTop\":[\"24px\"]}} -->\n<div class=\"gsbp-a15549e\"><!-- wp:greenshift-blocks/element {\"id\":\"gsbp-b8a15c6\",\"tag\":\"img\",\"localId\":\"gsbp-b8a15c6\",\"src\":\"http://dasiy.com/wp-content/uploads/2025/09/cropped-download.png\",\"alt\":\"\",\"mediaid\":346,\"originalWidth\":512,\"originalHeight\":512,\"styleAttributes\":{\"width\":[\"250px\",null,null,\"200px\"],\"height\":[\"250px\",null,null,\"200px\"]}} -->\n<img class=\"gsbp-b8a15c6\" src=\"http://dasiy.com/wp-content/uploads/2025/09/cropped-download.png\" alt=\"\" width=\"512\" height=\"512\" loading=\"lazy\"/>\n<!-- /wp:greenshift-blocks/element -->\n\n<!-- wp